/* SPDX-License-Identifier: MIT */ pragma solidity ^0.8.0; contract FandangoRuntime { event Seen(uint256 indexed tag, uint256 value); uint256 public value; mapping(uint256 => uint256) public values; function setup(uint256 seed) external { unchecked { value = seed & 1023; values[seed & 7] = seed + 1; emit Seen(0, value); } } function observe(uint256 key) external view returns (uint256, uint256) { return (value, values[key & 7]); } function helper(uint256 x) internal pure returns (uint256) { unchecked { return (x * 7) ^ 3; } } function mix(uint256 x, uint256 y) internal pure returns (uint256) { unchecked { return (x ^ y) + (x & 15); } } function run(uint256 a, uint256 b, bytes calldata data) external returns (uint256 r) { unchecked { uint256 limit = (a & 3) + 1; r = values[b & 7]; for (uint256 i = 0; i < limit; ++i) { r += mix(i, value); } value = r; values[a & 7] = r; emit Seen(1, r); return r; } } }
