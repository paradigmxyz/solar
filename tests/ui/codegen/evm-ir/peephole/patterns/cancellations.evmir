//@compile-flags: --pass peephole
//@filecheck:
@module module

// CHECK-LABEL: bb0:
// CHECK-COUNT-2: - not
bb0:
  push 1
  not
  not
  stop

// CHECK-LABEL: bb1:
// CHECK: - dup1
// CHECK: - pop
bb1:
  push 1
  dup1
  pop
  stop

// CHECK-LABEL: bb2:
// CHECK: - dup3
// CHECK: - pop
bb2:
  push 1
  push 2
  push 3
  dup3
  pop
  stop

// CHECK-LABEL: bb3:
// CHECK-COUNT-2: - swap1
bb3:
  push 1
  push 2
  swap1
  swap1
  stop

// CHECK-LABEL: bb4:
// CHECK-COUNT-2: - swap2
bb4:
  push 1
  push 2
  push 3
  swap2
  swap2
  stop

// CHECK-LABEL: bb5:
// CHECK: iszero
// CHECK-COUNT-2: - iszero
bb5:
  push 1
  iszero
  iszero
  iszero
  stop

// CHECK-LABEL: bb6:
// CHECK: - dup16
// CHECK: - pop
bb6:
  push 1
  push 2
  push 3
  push 4
  push 5
  push 6
  push 7
  push 8
  push 9
  push 10
  push 11
  push 12
  push 13
  push 14
  push 15
  push 16
  dup16
  pop
  stop

// CHECK-LABEL: bb7:
// CHECK-COUNT-2: - swap16
bb7:
  push 1
  push 2
  push 3
  push 4
  push 5
  push 6
  push 7
  push 8
  push 9
  push 10
  push 11
  push 12
  push 13
  push 14
  push 15
  push 16
  push 17
  swap16
  swap16
  stop
