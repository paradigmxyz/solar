//@compile-flags: --pass peephole
//@filecheck:
@module module

// CHECK-LABEL: {{^[ +].*}}bb0:
// CHECK: - dup2
// CHECK: {{^[ +].*}}add
// CHECK: - swap1
// CHECK: - pop
bb0:
  push 1
  push 2
  dup2
  add
  swap1
  pop
  stop

