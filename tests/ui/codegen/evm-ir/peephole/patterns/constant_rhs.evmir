//@compile-flags: --pass peephole
//@filecheck:
@module module

// CHECK-LABEL: {{^[ +].*}}bb0:
// CHECK: {{^[ +].*}}push 2
// CHECK: - push 0
// CHECK: - add
bb0:
  push 2
  push 0
  add
  stop

// CHECK-LABEL: {{^[ +].*}}bb1:
// CHECK: {{^[ +].*}}push 2
// CHECK: - push 0
// CHECK: - or
bb1:
  push 2
  push 0
  or
  stop

