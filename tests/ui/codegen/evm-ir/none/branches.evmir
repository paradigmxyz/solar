//@filecheck:
@module module

// CHECK-LABEL: {{^[ +].*}}bb0:
// CHECK: {{^[ +].*}}jumpi bb1, bb5
bb0:
  push 0
  calldataload
  dup1
  push 1
  eq
  jumpi bb1, bb5

// CHECK-LABEL: {{^[ +].*}}bb1:
// CHECK: {{^[ +].*}}jump bb4
bb1:
  pop
  jump bb4

// CHECK-LABEL: {{^[ +].*}}bb2:
// CHECK: {{^[ +].*}}selfdestruct
bb2:
  pop
  push 0xbeef
  selfdestruct !meta(source=admin-path)

// CHECK-LABEL: {{^[ +].*}}bb3 [cold]:
// CHECK: {{^[ +].*}}invalid
bb3 [cold]:
  pop
  invalid

// CHECK-LABEL: {{^[ +].*}}bb4:
// CHECK: {{^[ +].*}}stop
bb4:
  stop

// CHECK-LABEL: {{^[ +].*}}bb5:
// CHECK: {{^[ +].*}}jumpi bb2, bb3
bb5:
  dup1
  push 2
  eq
  jumpi bb2, bb3
