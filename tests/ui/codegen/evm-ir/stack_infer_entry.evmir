//@compile-flags: --pass stack-schedule
// Cross-block entry-stack inference with NO manual `(in ...)` signature. bb0
// computes %a and jumps to bb1; the scheduler infers bb1's incoming stack from
// bb0's exit (top first) instead of trusting a declared signature, so bb1
// schedules `add %a, %a` by duplicating the inherited %a. The blessed output
// shows the inferred `(in %a)` signature the pass writes back onto bb1.
bb0 (entry):
  %a = push 7
  jump bb1
bb1:
  %b = add %a, %a
  stop
