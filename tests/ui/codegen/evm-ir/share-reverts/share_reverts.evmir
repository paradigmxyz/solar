//@compile-flags: --pass share-reverts
//@filecheck:
@module module

// CHECK-LABEL: {{^[ +].*}}bb0:
// CHECK: - iszero
// CHECK: - push bb2
// CHECK: + push bb1
// CHECK: {{^[ +].*}}jumpi
// CHECK: - jump bb1
// CHECK: + jump bb2
bb0:
  push 1
  iszero
  push bb2
  jumpi
  jump bb1
bb1 [cold]:
  push 0
  dup1
  revert
bb2:
  stop
