//@compile-flags: --pass cfg-simplify
//@filecheck:
@module module

// CHECK-LABEL: bb0:
// CHECK: - jump bb1
// CHECK: - jump bb2
// CHECK: push 1
// CHECK: + stop
// CHECK-LABEL: bb3:
// CHECK: jump bb0
bb0:
  push bb3
  jump bb1
bb1:
  jump bb2
bb2:
  push 1
  jump bb4
bb3:
  push 2
  jump bb0
bb4:
  stop
