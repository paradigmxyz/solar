//@compile-flags: --pass stack-schedule
// A conditional `br` wants its condition on top. An unrelated push lands on top
// after the condition is produced, so the scheduler swaps the condition back up
// before the terminator.
@module module

bb0 (entry):
  %a = push 1
  %b = push 0
  %cond = eq %a, %b
  %junk = push 7
  br %cond, bb1, bb2
bb1:
  stop
bb2:
  invalid
