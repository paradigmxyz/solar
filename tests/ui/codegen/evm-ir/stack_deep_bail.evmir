//@compile-flags: --pass stack-schedule
// `%v0` sits below the DUP16/SWAP16 reach. This block ends in a linear `jump`,
// which hands a named value-word stack down to its successor, so spilling is
// disabled here: a reloaded word is anonymous and would break a successor's
// declared incoming identities. With spilling off the deep value cannot be
// reached, so the pass bails and leaves the block exactly as written rather than
// emitting a partial, broken schedule.
@module module

bb0 (entry):
  %v0 = push 0
  %v1 = push 1
  %v2 = push 2
  %v3 = push 3
  %v4 = push 4
  %v5 = push 5
  %v6 = push 6
  %v7 = push 7
  %v8 = push 8
  %v9 = push 9
  %v10 = push 10
  %v11 = push 11
  %v12 = push 12
  %v13 = push 13
  %v14 = push 14
  %v15 = push 15
  %v16 = push 16
  %r = add %v0, %v16
  jump bb1
bb1:
  stop
