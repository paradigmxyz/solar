//@compile-flags: --pass stack-schedule
// Cross-block stack consistency: a successor only declares the prefix of the
// predecessor's exit stack that it consumes. bb0 leaves [%top, %keep] (top
// first); bb1 declares just `(in %top)`, leaving %keep untouched below it. The
// verifier accepts this because the declared incoming stack is a prefix of the
// predecessor's exit stack.
bb0 (entry):
  %keep = push 1
  %top = push 2
  jump bb1
bb1 (in %top):
  %r = iszero %top
  stop
