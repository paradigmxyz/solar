//@compile-flags: --pass stack-schedule
// `switch` wants only its discriminant on top; the case immediates stay
// encoded. An unrelated push sits above the discriminant, so it is swapped back
// to the top before the terminator.
@module module

bb0 (entry):
  %x = push 3
  %sel = add %x, %x
  %junk = push 9
  switch %sel, default bb1, [1 => bb2]
bb1:
  stop
bb2:
  invalid
