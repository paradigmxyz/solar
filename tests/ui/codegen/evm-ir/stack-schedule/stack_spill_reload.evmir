//@compile-flags: --pass stack-schedule
// `%v0` sits at depth 16, below the DUP16/SWAP16 reach. The block ends in `stop`,
// which propagates no named value-word stack to a successor, so the scheduler is
// allowed to spill: it stores the deepest reachable live value (`%v1`) to a
// memory slot with `mstore`, lifting `%v0` into reach so `add %v0, %v16` can be
// arranged. The spilled `%v1` is then reloaded with `mload` before its later use
// in `mul`, keeping the schedule valid. The pass stays atomic and the verifier
// accepts the spilled/reloaded result.
@module module

bb0 (entry):
  %v0 = push 0
  %v1 = push 1
  %v2 = push 2
  %v3 = push 3
  %v4 = push 4
  %v5 = push 5
  %v6 = push 6
  %v7 = push 7
  %v8 = push 8
  %v9 = push 9
  %v10 = push 10
  %v11 = push 11
  %v12 = push 12
  %v13 = push 13
  %v14 = push 14
  %v15 = push 15
  %v16 = push 16
  %r = add %v0, %v16
  %s = mul %v1, %r
  stop
