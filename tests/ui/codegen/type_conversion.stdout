; module @TypeConversion
fn @narrowAddress(arg0: address) -> u16 {
  bb0 (entry):
    v3 = mstore 128, 0
    v5 = and arg0, 0xffffffffffffffffffffffffffffffffffffffff
    v7 = and v5, 0xffff
    v9 = mstore 128, v7
    returndata 128, 32
}

