; module @TypeConversion
fn @narrowAddress(arg0: address) -> u16 {
  bb0 (entry):
    v3 = mstore 128, 0
    v5 = and arg0, 0xffffffffffffffffffffffffffffffffffffffff
    v7 = and v5, 0xffff
    v9 = mload 64
    v11 = add v9, 32
    v13 = mstore 64, v11
    v14 = mstore v9, v7
    returndata v9, 32
}

