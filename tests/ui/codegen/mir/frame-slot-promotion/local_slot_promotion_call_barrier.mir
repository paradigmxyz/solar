//@compile-flags: --passes frame-slot-promotion,dce
//@filecheck:
@module LocalSlotPromotionCallBarrier
// CHECK-LABEL: {{^[ +].*}}fn @promote_across_unrelated_staticcall{{[( ]}}
// CHECK: {{^[ +].*}}[[CALL:v[0-9]+]] = staticcall
// CHECK: + {{v[0-9]+}} = add 9, [[CALL]]
fn @promote_across_unrelated_staticcall(arg0: address) -> u256 {
  bb0:
    v1 = internal_frame_addr 128
    mstore v1, 9
    v2 = staticcall 100000, arg0, 0, 0, 0, 0
    v3 = internal_frame_addr 128
    v4 = mload v3
    v5 = add v4, v2
    ret v5
}

// CHECK-LABEL: {{^[ +].*}}fn @keep_msize_observation{{[( ]}}
// CHECK: {{^[ +].*}}[[SLOT:v[0-9]+]] = internal_frame_addr 128
// CHECK: {{^[ +].*}}mstore [[SLOT]], 9
// CHECK: {{^[ +].*}}msize
// CHECK: {{^[ +].*}}mload
fn @keep_msize_observation() -> u256 {
  bb0:
    v1 = internal_frame_addr 128
    mstore v1, 9
    v2 = msize
    v3 = internal_frame_addr 128
    v4 = mload v3
    v5 = add v4, v2
    ret v5
}

// CHECK-LABEL: {{^[ +].*}}fn @promote_slot_with_unrelated_frame_hash{{[( ]}}
// CHECK: {{^[ +].*}}[[HASH:v[0-9]+]] = keccak256
// CHECK: + {{v[0-9]+}} = add 9, [[HASH]]
fn @promote_slot_with_unrelated_frame_hash() -> u256 {
  bb0:
    v1 = internal_frame_addr 128
    mstore v1, 9
    v2 = internal_frame_addr 192
    mstore v2, 1
    v3 = internal_frame_addr 192
    v4 = keccak256 v3, 32
    v5 = internal_frame_addr 128
    v6 = mload v5
    v7 = add v6, v4
    ret v7
}
