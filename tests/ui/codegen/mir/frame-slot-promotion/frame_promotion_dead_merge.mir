//@compile-flags: --passes frame-slot-promotion
//@filecheck:
@module FramePromotionDeadMerge
// CHECK-LABEL: {{^[ +].*}}fn @dead_merge{{[( ]}}
// CHECK: + [[COUNTER:v[0-9]+]] = phi [bb3: 0], [bb5: [[NEXT:v[0-9]+]]]
// CHECK: + [[NEXT]] = add [[COUNTER]], 1
// CHECK: + ret [[COUNTER]]
fn @dead_merge(arg0: u256, arg1: bool) -> u256 {
  bb0:
    br arg1, bb1, bb2
  bb1:
    jump bb3
  bb2:
    jump bb3
  bb3:
    v1 = internal_frame_addr 128
    mstore v1, 0
    jump bb4
  bb4:
    v2 = internal_frame_addr 128
    v3 = mload v2
    v4 = lt v3, arg0
    br v4, bb5, bb6
  bb5:
    v5 = add v3, 1
    v6 = internal_frame_addr 128
    mstore v6, v5
    jump bb4
  bb6:
    v7 = internal_frame_addr 128
    v8 = mload v7
    ret v8
}
