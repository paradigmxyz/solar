//@ check-pass
//@compile-flags: --passes frame-slot-promotion,dce
@module FramePromotionSameBlock
fn @same_block() -> u256 {
  bb0:
    v1 = internal_frame_addr 128
    mstore v1, 7
    v2 = internal_frame_addr 128
    v3 = mload v2
    v4 = add v3, 1
    v5 = internal_frame_addr 128
    mstore v5, v4
    v6 = internal_frame_addr 128
    v7 = mload v6
    ret v7
}
