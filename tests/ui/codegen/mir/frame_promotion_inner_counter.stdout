// === ROOT/tests/ui/codegen/mir/frame_promotion_inner_counter.mir (after frame-slot-promotion,cfg-simplify,dce) ===
; module @NestedCounter
fn @nested(arg0: u256, arg1: u256) -> u256 {
  bb0 (entry):
    jump bb1
  bb1:
    v31 = phi [bb0: 0], [bb5: v32]
    v33 = phi [bb0: 0], [bb5: v27]
    v8 = lt v33, arg0
    br v8, bb2, bb6
  bb2:
    jump bb3
  bb3:
    v32 = phi [bb2: v31], [bb4: v17]
    v35 = phi [bb2: 0], [bb4: v22]
    v13 = lt v35, arg1
    br v13, bb4, bb5
  bb4:
    v17 = add v32, 1
    v22 = add v35, 1
    jump bb3
  bb5:
    v27 = add v33, 1
    jump bb1
  bb6:
    ret v31
}
