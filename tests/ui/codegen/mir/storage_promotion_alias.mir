//@compile-flags: --pass storage-promotion
; module @StoragePromotionAlias
fn @reject_two_symbolic_slots(arg0: u256, arg1: u256) [selector=0x01020304] {
  bb0 (entry):
    sstore arg0, 1
    sstore arg1, 2
    jump bb1
  bb1:
    br true, bb2, bb4
  bb2:
    v1 = sload arg0
    v2 = mul v1, 2
    sstore arg0, v2
    v3 = sload arg1
    v4 = add v3, 3
    sstore arg1, v4
    jump bb3
  bb3:
    jump bb1
  bb4:
    stop
}

fn @reject_symbolic_and_constant_slots(arg0: u256) [selector=0x01020304] {
  bb0 (entry):
    sstore arg0, 1
    sstore 7, 2
    jump bb1
  bb1:
    br true, bb2, bb4
  bb2:
    v1 = sload arg0
    v2 = mul v1, 2
    sstore arg0, v2
    v3 = sload 7
    v4 = add v3, 3
    sstore 7, v4
    jump bb3
  bb3:
    jump bb1
  bb4:
    stop
}

fn @promote_two_constant_slots() [selector=0x01020304] {
  bb0 (entry):
    sstore 0, 1
    sstore 1, 2
    jump bb1
  bb1:
    br true, bb2, bb4
  bb2:
    v1 = sload 0
    v2 = mul v1, 2
    sstore 0, v2
    v3 = sload 1
    v4 = add v3, 3
    sstore 1, v4
    jump bb3
  bb3:
    jump bb1
  bb4:
    stop
}

fn @promote_same_base_distinct_offsets(arg0: u256) [selector=0x01020304] {
  bb0 (entry):
    v1 = add arg0, 1
    sstore v1, 1
    v2 = add arg0, 2
    sstore v2, 2
    jump bb1
  bb1:
    br true, bb2, bb4
  bb2:
    v3 = add arg0, 1
    v4 = sload v3
    v5 = mul v4, 2
    v6 = add arg0, 1
    sstore v6, v5
    v7 = add arg0, 2
    v8 = sload v7
    v9 = add v8, 3
    v10 = add arg0, 2
    sstore v10, v9
    jump bb3
  bb3:
    jump bb1
  bb4:
    stop
}
