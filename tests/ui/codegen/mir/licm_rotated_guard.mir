//@compile-flags: --pass licm
; Rotated loop: the body (mstore + mload) sits BEFORE the exit guard inside the
; header block, so it executes for v1 = 0..10 inclusive (11 times) while the
; `lt v1, 10` trip count is 10. The mstore range really is [0, 352): the final
; iteration writes 1 at byte 320 BEFORE the mload reads it, so the mload must
; stay in the loop.
; module @LicmRotatedGuard
fn @rotated_guard_overlap() -> u256 {
  bb0 (entry):
    jump bb1
  bb1:
    v1 = phi [bb0: 0], [bb2: v9]
    v4 = mul v1, 32
    mstore v4, 1
    v3 = mload 320
    v2 = lt v1, 10
    br v2, bb2, bb3
  bb2:
    v9 = add v1, 1
    jump bb1
  bb3:
    ret v3
}

; Self-loop do-while variant of the same off-by-one: guard on the pre-increment
; phi at the bottom of the single-block loop. The body runs with v1 = 0..10.
fn @dowhile_latch_guard_overlap() -> u256 {
  bb0 (entry):
    jump bb1
  bb1:
    v1 = phi [bb0: 0], [bb1: v9]
    v4 = mul v1, 32
    mstore v4, 1
    v3 = mload 320
    v9 = add v1, 1
    v2 = lt v1, 10
    br v2, bb1, bb2
  bb2:
    ret v3
}

; Top-tested control: the guard is the header's terminator, so the store block
; only executes after the bound check passed and the store range is exactly
; [0, 320). The mload at 320 is genuinely disjoint and is hoisted.
fn @top_tested_control() -> u256 {
  bb0 (entry):
    jump bb1
  bb1:
    v1 = phi [bb0: 0], [bb2: v9]
    v2 = lt v1, 10
    br v2, bb2, bb3
  bb2:
    v4 = mul v1, 32
    mstore v4, 1
    v3 = mload 320
    v9 = add v1, 1
    jump bb1
  bb3:
    ret v3
}

; Stores in the header observe the post-increment value of the exiting
; iteration, so their range is widened one stride to [0, 352); a load one
; stride further is still provably disjoint and may be hoisted.
fn @disjoint_past_widened_range() -> u256 {
  bb0 (entry):
    jump bb1
  bb1:
    v1 = phi [bb0: 0], [bb2: v9]
    v4 = mul v1, 32
    mstore v4, 1
    v3 = mload 384
    v2 = lt v1, 10
    br v2, bb2, bb3
  bb2:
    v9 = add v1, 1
    jump bb1
  bb3:
    ret v3
}
