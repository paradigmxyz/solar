// === ROOT/tests/ui/codegen/mir/check_elim_loop_increment.mir (after check-elim) ===
@module CheckElimLoopIncrement
fn @fold_increment_check(arg0: u256) -> u256 {
  bb0 (entry):
    jump bb1
  bb1:
    v0 = phi [bb0: 0], [bb4: v2]
    v1 = lt v0, arg0
    br v1, bb2, bb5
  bb2:
    v2 = add v0, 1
    v3 = lt v2, v0
    jump bb4
  bb3:
    revert 0, 0
  bb4:
    jump bb1
  bb5:
    ret v0
}

fn @keep_non_dominating_guard(arg0: u256, arg1: bool) -> u256 {
  bb0 (entry):
    br arg1, bb1, bb2
  bb1:
    v0 = lt arg0, 100
    br v0, bb3, bb2
  bb2:
    jump bb3
  bb3:
    v1 = add arg0, 1
    v2 = lt v1, arg0
    br v2, bb4, bb5
  bb4:
    revert 0, 0
  bb5:
    ret v1
}
