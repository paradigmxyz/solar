//@compile-flags: --pass memory-dse
//@filecheck:
@module MemoryDseKeccakFold
// CHECK-LABEL: fn @fold_constant_scratch_keccak
// CHECK: + ret 0xeddb6698d7c569ff62ff64f1f1492bf14a54594835ba0faac91f84b4f5d81460
fn @fold_constant_scratch_keccak() -> bytes32 {
  bb0:
    mstore 0, 7
    mstore 32, 5
    v2 = keccak256 0, 64
    ret v2
}

// CHECK-LABEL: fn @keep_dynamic_word
// CHECK: mstore 0, arg0
// CHECK: [[HASH:v[0-9]+]] = keccak256 0, 64
fn @keep_dynamic_word(arg0: u256) -> bytes32 {
  bb0:
    mstore 0, arg0
    mstore 32, 5
    v2 = keccak256 0, 64
    ret v2
}

// CHECK-LABEL: fn @keep_after_memory_clobber
// CHECK: calldatacopy
// CHECK: [[HASH:v[0-9]+]] = keccak256 0, 64
fn @keep_after_memory_clobber() -> bytes32 {
  bb0:
    mstore 0, 7
    mstore 32, 5
    calldatacopy 0, 0, 32
    v3 = keccak256 0, 64
    ret v3
}
