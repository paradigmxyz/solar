//@compile-flags: --passes memory-dse
//@filecheck:
@module AbiEncodeMemoryEffects

// CHECK-LABEL: fn @encode
// CHECK: mstore arg0, 1
// CHECK: [[ENCODED:v[0-9]+]] = abi_encode
fn @encode(arg0: memptr) -> memoryslice {
  bb0:
    mstore arg0, 1
    v0 = abi_encode [memory_bytes], args arg0
    ret v0
}
