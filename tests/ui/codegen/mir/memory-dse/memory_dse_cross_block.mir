//@compile-flags: --pass memory-dse
//@filecheck:
@module MemoryDseCrossBlock

// CHECK-LABEL: fn @remove_store_overwritten_on_unique_edge
// CHECK: - mstore 128, 1
// CHECK: + ret 2
fn @remove_store_overwritten_on_unique_edge() -> u256 {
  bb0:
    mstore 128, 1
    jump bb1
  bb1:
    mstore 128, 2
    v3 = mload 128
    ret v3
}

// CHECK-LABEL: fn @keep_store_read_before_successor_overwrite
// CHECK: mstore 128, 1
// CHECK: [[LOAD:v[0-9]+]] = mload 128
fn @keep_store_read_before_successor_overwrite() -> u256 {
  bb0:
    mstore 128, 1
    jump bb1
  bb1:
    v2 = mload 128
    mstore 128, 2
    ret v2
}

// CHECK-LABEL: fn @keep_store_into_multi_pred_successor
// CHECK: mstore 128, 1
// CHECK: + ret 2
fn @keep_store_into_multi_pred_successor(arg0: bool) -> u256 {
  bb0:
    br arg0, bb1, bb2
  bb1:
    mstore 128, 1
    jump bb3
  bb2:
    jump bb3
  bb3:
    mstore 128, 2
    v4 = mload 128
    ret v4
}
