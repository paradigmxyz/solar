//@compile-flags: --pass memory-dse
//@filecheck:
@module MemoryDseCopyRanges

// A full-word copy write to the same range makes the prior store dead.
// CHECK-LABEL: fn @remove_store_overwritten_by_codecopy
// CHECK: - mstore 0, 1
// CHECK: codecopy 0, 0, 64
fn @remove_store_overwritten_by_codecopy() -> u256 {
  bb0:
    mstore 0, 1
    codecopy 0, 0, 64
    ret 0
}

// A partial disjoint copy range must not kill the store read from the next word.
// CHECK-LABEL: fn @keep_store_after_partial_copy
// CHECK: mstore 32, 1
// CHECK: codecopy 0, 0, 32
// CHECK: [[LOAD:v[0-9]+]] = mload 32
fn @keep_store_after_partial_copy() -> u256 {
  bb0:
    mstore 32, 1
    codecopy 0, 0, 32
    v2 = mload 32
    ret v2
}

// Updating the free-memory pointer at 0x40 and zeroing the data area do not
// clobber the fresh allocation length word at the old FMP.
// CHECK-LABEL: fn @forward_fresh_array_length
// CHECK: calldatacopy
// CHECK: + ret 3
fn @forward_fresh_array_length() -> u256 {
  bb0:
    v0 = mload 64
    mstore v0, 3
    v1 = add v0, 128
    mstore 64, v1
    v2 = add v0, 32
    calldatacopy v2, 0, 96
    v3 = mload v0
    ret v3
}
