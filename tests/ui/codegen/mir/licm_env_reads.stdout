// === ROOT/tests/ui/codegen/mir/licm_env_reads.mir (after licm) ===
; module @LicmEnvReads
fn @keep_balance_with_call() -> u256 {
  bb0 (entry):
    jump bb1
  bb1:
    br 1, bb2, bb3
  bb2:
    v2 = balance 0xbeef
    v4 = mul v2, 3
    v12 = call 0x3e8, 0xbeef, 1, 0, 0, 0, 0
    jump bb1
  bb3:
    ret v4
}

fn @hoist_balance_without_calls() -> u256 {
  bb0 (entry):
    v2 = balance 0xbeef
    v4 = mul v2, 3
    jump bb1
  bb1:
    br 1, bb2, bb3
  bb2:
    jump bb1
  bb3:
    ret v4
}

fn @keep_extcodesize_with_create() -> u256 {
  bb0 (entry):
    jump bb1
  bb1:
    br 1, bb2, bb3
  bb2:
    v2 = extcodesize 0xbeef
    v4 = mul v2, 3
    v8 = create 0, 0, 32
    jump bb1
  bb3:
    ret v4
}

fn @keep_returndatasize_with_staticcall() -> u256 {
  bb0 (entry):
    jump bb1
  bb1:
    br 1, bb2, bb3
  bb2:
    v1 = returndatasize
    v3 = mul v1, 3
    v10 = staticcall 0x3e8, 0xbeef, 0, 0, 0, 0
    jump bb1
  bb3:
    ret v3
}

fn @keep_msize() -> u256 {
  bb0 (entry):
    jump bb1
  bb1:
    br 1, bb2, bb3
  bb2:
    v1 = msize
    v3 = mul v1, 3
    jump bb1
  bb3:
    ret v3
}
