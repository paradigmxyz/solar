    v10 = sub v7, 32
    v11 = add v8, v10
    mstore v11, 0
    jump bb2
  bb2:
    v12 = slice_ptr arg0
    v13 = add v8, v7
    calldatacopy v8, v12, v4
    v14 = sub v13, v1
    v15 = add v14, 0
    v16 = add v15, 31
    v17 = not 31
    v18 = and v16, v17
    v19 = alloc raw, exact, uninitialized, infallible, v18
    v20 = make_memory_slice v19, v15
