  bb0 (entry):
    v1 = alloc raw, exact, uninitialized, infallible, 64
    mstore v1, 0x1234567800000000000000000000000000000000000000000000000000000000
    v2 = add v1, 4
    mstore v2, arg0
    v3 = make_memory_slice v1, 36
    ret v3
}

fn @dynamic(arg0: calldataslice) -> memoryslice {
  bb0 (entry):
    v1 = fmp
    v2 = add v1, 32
    v3 = sub v2, v1
    mstore v1, v3
    v4 = slice_len arg0
    mstore v2, v4
    v5 = not 31
    v6 = add v4, 31
