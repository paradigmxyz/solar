// === ROOT/tests/ui/codegen/mir/cse_memory_alias.mir (after cse) ===
; module @CseMemoryAlias
fn @reuse_same_memory_load(arg0: u256) -> u256 {
  bb0 (entry):
    v1 = mload arg0
    v3 = add v1, v1
    ret v3
}

fn @reuse_after_disjoint_memory_store(arg0: u256) -> u256 {
  bb0 (entry):
    v2 = mload 64
    mstore 96, arg0
    v8 = add v2, v2
    v9 = add v8, v2
    ret v9
}

fn @keep_after_overlapping_memory_store(arg0: u256) -> u256 {
  bb0 (entry):
    v2 = mload 64
    mstore 80, arg0
    v5 = mload 64
    v6 = add v2, v5
    ret v6
}

fn @reuse_keccak_after_disjoint_memory_store(arg0: u256) -> u256 {
  bb0 (entry):
    v3 = keccak256 128, 64
    mstore 64, arg0
    v8 = add v3, v3
    ret v8
}

fn @keep_mload_after_external_call(arg0: u256) -> u256 {
  bb0 (entry):
    v2 = mload 64
    v9 = call 0x186a0, arg0, 0, 0, 0, 96, 32
    v11 = mload 64
    v12 = add v2, v11
    v13 = add v12, v9
    ret v13
}
