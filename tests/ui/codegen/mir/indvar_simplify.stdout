// === ROOT/tests/ui/codegen/mir/indvar_simplify.mir (after indvar-simplify) ===
; module @IndVarSimplify
fn @strength_reduce_shifted_address(arg0: u256) -> u256 {
  bb0 (entry):
    jump bb1
  bb1:
    v3 = phi [bb0: 0], [bb2: v2]
    v11 = phi [bb0: arg0], [bb2: v13]
    v5 = lt v3, 4
    br v5, bb2, bb3
  bb2:
    v7 = shl 5, v3
    v8 = add arg0, v7
    mstore v11, v3
    v2 = add v3, 1
    v13 = add v11, 32
    jump bb1
  bb3:
    ret 0
}

fn @strength_reduce_scaled_address_with_offset(arg0: u256) -> u256 {
  bb0 (entry):
    v14 = add arg0, 4
    jump bb1
  bb1:
    v3 = phi [bb0: 0], [bb2: v2]
    v15 = phi [bb0: v14], [bb2: v17]
    v5 = lt v3, 4
    br v5, bb2, bb3
  bb2:
    v7 = mul v3, 32
    v8 = add arg0, v7
    v10 = add v8, 4
    mstore v15, v3
    v2 = add v3, 1
    v17 = add v15, 32
    jump bb1
  bb3:
    ret 0
}

