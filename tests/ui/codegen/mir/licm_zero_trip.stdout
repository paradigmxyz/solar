// === ROOT/tests/ui/codegen/mir/licm_zero_trip.mir (after licm) ===
; module @LicmZeroTrip
fn @keep_sload_zero_trip() -> u256 {
  bb0 (entry):
    v0 = calldatasize
    jump bb1
  bb1:
    v3 = phi [bb0: 0], [bb2: v2]
    v4 = lt v3, v0
    br v4, bb2, bb3
  bb2:
    v6 = sload 5 !metadata(storage=slot(5))
    v2 = add v3, 1
    jump bb1
  bb3:
    ret v6
}

fn @keep_mload_zero_trip() -> u256 {
  bb0 (entry):
    v0 = calldatasize
    jump bb1
  bb1:
    v3 = phi [bb0: 0], [bb2: v2]
    v4 = lt v3, v0
    br v4, bb2, bb3
  bb2:
    v6 = mload 0x1000000
    v2 = add v3, 1
    jump bb1
  bb3:
    ret v6
}

fn @hoist_sload_known_trip() -> u256 {
  bb0 (entry):
    v6 = sload 5 !metadata(storage=slot(5))
    jump bb1
  bb1:
    v2 = phi [bb0: 0], [bb2: v1]
    v4 = lt v2, 10
    br v4, bb2, bb3
  bb2:
    v1 = add v2, 1
    jump bb1
  bb3:
    ret v6
}

fn @hoist_mload_dominates_exits() -> u256 {
  bb0 (entry):
    v1 = mload 64
    v3 = calldataload 0
    jump bb1
  bb1:
    v4 = lt v1, v3
    br v4, bb1, bb2
  bb2:
    ret v1
}

fn @keep_mload_msize_in_function() -> u256 {
  bb0 (entry):
    jump bb1
  bb1:
    v2 = phi [bb0: 0], [bb2: v1]
    v4 = lt v2, 10
    br v4, bb2, bb3
  bb2:
    v6 = mload 64
    v1 = add v2, 1
    jump bb1
  bb3:
    v8 = msize
    v9 = add v6, v8
    ret v9
}
