//@ check-pass
//@compile-flags: --passes lower-slices
@module SplitAggregates

fn @select_slice(arg0: calldataslice, arg1: calldataslice, arg2: bool) -> u256 {
  bb0:
    v3 = select arg2, arg0, arg1
    v4 = slice_len v3
    ret v4
}

fn @phi_slice(arg0: calldataslice, arg1: calldataslice, arg2: bool) -> u256 {
  bb0:
    br arg2, bb1, bb2
  bb1:
    jump bb3
  bb2:
    jump bb3
  bb3:
    v3 = phi [bb1: arg0], [bb2: arg1]
    v4 = slice_len v3
    ret v4
}
