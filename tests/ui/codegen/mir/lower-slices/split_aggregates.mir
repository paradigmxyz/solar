//@compile-flags: --passes lower-slices
//@filecheck:
@module SplitAggregates

// CHECK-LABEL: fn @select_slice
// CHECK: + [[POINTER:v[0-9]+]] = select arg4, arg0, arg2
// CHECK: + [[LENGTH:v[0-9]+]] = select arg4, arg1, arg3
// CHECK: + ret [[LENGTH]]
fn @select_slice(arg0: calldataslice, arg1: calldataslice, arg2: bool) -> u256 {
  bb0:
    v3 = select arg2, arg0, arg1
    v4 = slice_len v3
    ret v4
}

// CHECK-LABEL: fn @phi_slice
// CHECK: + [[POINTER:v[0-9]+]] = phi [bb1: arg0], [bb2: arg2]
// CHECK: + [[LENGTH:v[0-9]+]] = phi [bb1: arg1], [bb2: arg3]
// CHECK: + ret [[LENGTH]]
fn @phi_slice(arg0: calldataslice, arg1: calldataslice, arg2: bool) -> u256 {
  bb0:
    br arg2, bb1, bb2
  bb1:
    jump bb3
  bb2:
    jump bb3
  bb3:
    v3 = phi [bb1: arg0], [bb2: arg1]
    v4 = slice_len v3
    ret v4
}
