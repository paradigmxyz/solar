//@compile-flags: --passes lower-abi,lower-slices
//@filecheck:
@module LowerSlices
// CHECK-LABEL: fn @entry
// CHECK: + fn @entry
fn @entry(arg0: calldataslice) [selector=0x12345678] {
  bb0:
    v1 = internal_call @len, 1, arg0
    mstore 128, v1
    returndata 128, 32
}

// CHECK-LABEL: after lower-slices
// CHECK: fn @len
// CHECK: + [[HEAD:v[0-9]+]] = add arg0, 4
// CHECK: + [[LENGTH:v[0-9]+]] = calldataload [[HEAD]]
// CHECK: + ret [[LENGTH]]
fn @len(arg0: calldataslice) -> u256 {
  bb0:
    v1 = slice_len arg0
    ret v1
}

// CHECK-LABEL: fn @tail
// CHECK: + [[POINTER:v[0-9]+]] = add arg0, arg2
// CHECK: + [[LENGTH:v[0-9]+]] = sub arg1, arg2
// CHECK: + {{v[0-9]+}} = internal_call @pair_len, 1, [[POINTER]], [[LENGTH]]
fn @tail(arg0: calldataslice, arg1: u256) -> u256 {
  bb0:
    v2 = slice_ptr arg0
    v3 = slice_len arg0
    v4 = add v2, arg1
    v5 = sub v3, arg1
    v6 = make_calldata_slice v4, v5
    v7 = internal_call @pair_len, 1, v6
    ret v7
}

// CHECK-LABEL: fn @pair_len
// CHECK: + ret arg1
fn @pair_len(arg0: calldataslice) -> u256 {
  bb0:
    v1 = slice_len arg0
    ret v1
}

// CHECK-LABEL: fn @memory
// CHECK: + [[END:v[0-9]+]] = add arg0, arg1
// CHECK: ret [[END]]
fn @memory(arg0: memptr, arg1: u256) -> u256 {
  bb0:
    v2 = make_memory_slice arg0, arg1
    v3 = slice_ptr v2
    v4 = slice_len v2
    v5 = add v3, v4
    ret v5
}
