//@compile-flags: --pass lower-evm-shaped
//@filecheck:
// A resultless internal call to a callee that never returns (no `ret`, no
// `stop` — it ends in `returndata`) models a returning edge that does not
// exist. The evm-shaped phase rewrites it into a `tail_call` — arguments
// included — and drops the dead remainder of the block. The rewrite only
// applies to callees the backend statically frames: `@spin` cannot return
// either, but it is recursive, so its call stays an ordinary `internal_call`.
// `@entry` is present so the module satisfies the memory-lowered phase contract.
@module LowerEvmShaped
@phase memory-lowered
fn @entry() {
  bb0:
    v0 = calldataload 0
    v2 = shr 224, v0
    switch v2, default bb2, [7 => bb1]
  bb1:
    tail_call fn1
  bb2:
    revert 0, 0
}
// CHECK-LABEL: {{^[ +].*}}fn @caller{{[( ]}}
// CHECK: - internal_call @fused
// CHECK: + tail_call @fused, {{v[0-9]+}}
fn @caller() [selector=0x00000007] {
  bb0:
    v0 = calldataload 4
    internal_call fn2, 0, v0
    stop
}
fn @fused(arg0: u256) {
  bb0:
    mstore 128, arg0
    returndata 128, 32
}
// CHECK-LABEL: {{^[ +].*}}fn @spin{{[( ]}}
// CHECK: {{^[ +].*}}internal_call @spin
fn @spin(arg0: u256) {
  bb0:
    internal_call fn3, 0, arg0
    revert 0, 0
}
