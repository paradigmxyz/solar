//@compile-flags: --pass lower-dispatch
//@filecheck:
// The dispatch phase synthesizes an `entry` function that reads the selector
// (calldataload(0) >> 224) and switches to one argument-free internal call per
// external wrapper, defaulting to a revert. It requires the `abi` phase, whose
// wrappers are already argument-free.
@module LowerDispatch
@phase abi
// CHECK-LABEL: after lower-dispatch
// CHECK: + fn @entry{{[( ]}}
// CHECK: + [[SIZE:v[0-9]+]] = calldatasize
// CHECK: + jumpi [[SIZE]]
// CHECK: + [[SHORT:v[0-9]+]] = lt {{v[0-9]+}}, 4
// CHECK: + jumpi [[SHORT]]
// CHECK: + [[SELECTOR:v[0-9]+]] = shr 224
// CHECK: + switch [[SELECTOR]], default {{.*}}[0x12000000 =>
// CHECK: + tail_call @ping
// CHECK: + tail_call @pong
fn @ping() [selector=0x12000000] {
  bb0:
    stop
}
fn @pong() [selector=0x8d3a3e57] {
  bb0:
    stop
}
