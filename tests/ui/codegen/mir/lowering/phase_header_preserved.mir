//@compile-flags: --pipeline-default
//@filecheck:
// CHECK: @module PhaseHeaderPreserved
// CHECK-NEXT: @phase optimized
// Re-running the default pipeline on its own output keeps the phase instead of
// rejecting the idempotent optimized-to-optimized transition.
@module PhaseHeaderPreserved
@phase optimized
fn @f() {
  bb0:
    stop
}
