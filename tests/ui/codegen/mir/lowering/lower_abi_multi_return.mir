//@compile-flags: --pass lower-abi
//@filecheck:
// Static multi-return wrappers must encode every return word, not just the
// first call result.
@module LowerAbiMultiReturn
// CHECK-LABEL: fn @pair
// CHECK: + mstore 128, arg0
// CHECK: + mstore 160, {{v[0-9]+}}
// CHECK: + returndata 128, 64
fn @pair(arg0: u256) -> (u256, u256) [selector=0x1f6a26ff] {
  bb0:
    v1 = add arg0, 1
    ret arg0, v1
}
