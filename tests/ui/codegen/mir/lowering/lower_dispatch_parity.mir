//@compile-flags: --pass lower-dispatch
//@filecheck:
// Full dispatcher parity with the backend: empty calldata routes to `receive`,
// the switch default routes to `fallback`, and the nonpayable entry gets a
// per-case callvalue check because a payable entry exists, so the check cannot
// be hoisted. Receive is payable and needs no check.
@module DispatchParity
@phase abi
// CHECK-LABEL: after lower-dispatch
// CHECK: + fn @entry
// CHECK: + tail_call @recv
// CHECK: + switch {{.*}}default bb6, [1 => bb4, 2 => bb5]
// CHECK: + tail_call @pay
// CHECK: + tail_call @nopay
// CHECK: + tail_call @fb
fn @pay() [selector=0x00000001, payable] {
  bb0:
    stop
}
fn @nopay() [selector=0x00000002] {
  bb0:
    stop
}
fn @recv() [receive, payable] {
  bb0:
    stop
}
fn @fb() [fallback, payable] {
  bb0:
    stop
}
