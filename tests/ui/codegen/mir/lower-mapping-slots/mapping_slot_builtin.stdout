// === ROOT/tests/ui/codegen/mir/mapping_slot_builtin.mir (after cse,lower-mapping-slots,lower-slices) ===
; module @MappingSlotBuiltin
fn @word(arg0: u256) -> u256 {
  bb0 (entry):
    mstore 0, arg0 !metadata(memory=scratch)
    mstore 32, 7 !metadata(memory=scratch)
    v3 = keccak256 0, 64 !metadata(memory=scratch)
    v2 = add v3, v3
    ret v2
}

fn @word_across_reverting_branch(arg0: u256, arg1: bool) -> u256 {
  bb0 (entry):
    mstore 0, arg0 !metadata(memory=scratch)
    mstore 32, 7 !metadata(memory=scratch)
    v3 = keccak256 0, 64 !metadata(memory=scratch)
    br arg1, bb1, bb2
  bb1:
    mstore 0, 1
    revert 0, 0
  bb2:
    v2 = add v3, v3
    ret v2
}

fn @memory(arg0: memptr) -> u256 {
  bb0 (entry):
    v3 = mload arg0
    v4 = add arg0, 32
    v5 = fmp
    mcopy v5, v4, v3
    v6 = add v5, v3
    mstore v6, 9
    v7 = add v3, 32
    v8 = keccak256 v5, v7
    mstore arg0, 1
    v9 = mload arg0
    v10 = add arg0, 32
    v11 = fmp
    mcopy v11, v10, v9
    v12 = add v11, v9
    mstore v12, 9
    v13 = add v9, 32
    v14 = keccak256 v11, v13
    v2 = add v8, v14
    ret v2
}

fn @calldata(arg0: calldataptr, arg1: u256) -> u256 {
  bb0 (entry):
    v5 = fmp
    calldatacopy v5, arg0, arg1
    v6 = add v5, arg1
    mstore v6, 11
    v7 = add arg1, 32
    v8 = keccak256 v5, v7
    v2 = add v8, v8
    ret v2
}
