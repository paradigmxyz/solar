//@compile-flags: --pass sccp
//@filecheck:
@module SccpEdge
// CHECK-LABEL: {{^[ +].*}}fn @phi_ignores_unreachable_predecessor{{[( ]}}
// CHECK: + jump bb1
// CHECK: + ret 11
fn @phi_ignores_unreachable_predecessor() -> u256 {
  bb0:
    v0 = eq 1, 1
    br v0, bb1, bb2
  bb1:
    jump bb3
  bb2:
    jump bb3
  bb3:
    v1 = phi [bb1: 11], [bb2: 22]
    ret v1
}

// CHECK-LABEL: {{^[ +].*}}fn @unknown_branch_keeps_phi{{[( ]}}
// CHECK: {{^[ +].*}}br arg0, bb1, bb2
// CHECK: {{^[ +].*}}{{v[0-9]+}} = phi [bb1: 11], [bb2: 22]
fn @unknown_branch_keeps_phi(arg0: bool) -> u256 {
  bb0:
    br arg0, bb1, bb2
  bb1:
    jump bb3
  bb2:
    jump bb3
  bb3:
    v1 = phi [bb1: 11], [bb2: 22]
    ret v1
}

// CHECK-LABEL: {{^[ +].*}}fn @constant_switch_selects_one_case{{[( ]}}
// CHECK: + jump bb2
// CHECK: {{^[ +].*}}ret 22
fn @constant_switch_selects_one_case() -> u256 {
  bb0:
    switch 2, default bb4, [1 => bb1, 2 => bb2, 3 => bb3]
  bb1:
    ret 11
  bb2:
    ret 22
  bb3:
    ret 33
  bb4:
    ret 44
}
