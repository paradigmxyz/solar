//@compile-flags: --pass pure-eval
//@filecheck:
@module PureEvalLoop
// CHECK-LABEL: {{^[ +].*}}fn @bounded_loop{{[( ]}}
// CHECK: - jump bb1
// CHECK: + ret 3
fn @bounded_loop() -> u256 {
  bb0:
    jump bb1
  bb1:
    v0 = phi [bb0: 0], [bb2: 3]
    v1 = lt v0, 3
    jumpi v1, bb2, bb3
  bb2:
    jump bb1
  bb3:
    ret v0
}

// CHECK-LABEL: {{^[ +].*}}fn @with_arg{{[( ]}}
// CHECK: {{^[ +].*}}{{v[0-9]+}} = add arg0, 1
fn @with_arg(arg0: u256) -> u256 {
  bb0:
    v0 = add arg0, 1
    ret v0
}

fn @unknown_case_precedes_match() -> u256 {
  bb0:
    v0 = address
    switch 1, default bb3, [v0 => bb1, 1 => bb2]
  bb1:
    ret 1
  bb2:
    ret 2
  bb3:
    ret 3
}
