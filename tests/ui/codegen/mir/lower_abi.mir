//@compile-flags: --pass lower-abi
// The ABI phase absorbs each external function's arguments: every `Arg` is
// redefined as a `calldataload` of its head word, the function keeps its
// selector and fused encode, and a pristine `.body` copy with parameters is
// appended for internal callers. Advances the module to the `abi` phase.
; module @LowerAbi
fn @add(arg0: u256, arg1: u256) [selector=0x771602f7] {
  bb0 (entry):
    v2 = add arg0, arg1
    mstore 128, v2
    returndata 128, 32
}
fn @flag(arg0: bool) [selector=0x0d2020dd] {
  bb0 (entry):
    mstore 128, arg0
    returndata 128, 32
}
