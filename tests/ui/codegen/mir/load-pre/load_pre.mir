//@compile-flags: --pass load-pre
//@filecheck:
// Basic storage shapes: a join reload of a slot loaded in both arms becomes a
// phi; an sstore in one arm forwards its stored value into the phi. A load
// available on one diamond arm only is compensated on the other arm for
// expensive storage/transient/keccak keys; cheap memory keys keep the stricter
// loop-carried-only policy (load_pre_memory.mir).
@module LoadPre
// CHECK-LABEL: {{^[ +].*}}fn @full_diamond{{[( ]}}
// CHECK: + [[MERGE:v[0-9]+]] = phi [bb1: {{v[0-9]+}}], [bb2: {{v[0-9]+}}]
// CHECK: + ret [[MERGE]]
fn @full_diamond(arg0: bool) -> u256 {
  bb0:
    jumpi arg0, bb1, bb2
  bb1:
    v1 = sload 5
    jump bb3
  bb2:
    v2 = sload 5
    jump bb3
  bb3:
    v3 = sload 5
    ret v3
}

// CHECK-LABEL: {{^[ +].*}}fn @store_forward_arm{{[( ]}}
// CHECK: + [[MERGE:v[0-9]+]] = phi [bb1: arg1], [bb2: {{v[0-9]+}}]
// CHECK: + ret [[MERGE]]
fn @store_forward_arm(arg0: bool, arg1: u256) -> u256 {
  bb0:
    jumpi arg0, bb1, bb2
  bb1:
    sstore 5, arg1
    jump bb3
  bb2:
    v2 = sload 5
    jump bb3
  bb3:
    v3 = sload 5
    ret v3
}

// CHECK-LABEL: {{^[ +].*}}fn @partial_insert_diamond{{[( ]}}
// CHECK: + [[INSERTED:v[0-9]+]] = sload 5
// CHECK: + [[MERGE:v[0-9]+]] = phi [bb1: {{v[0-9]+}}], [bb2: [[INSERTED]]]
fn @partial_insert_diamond(arg0: bool) -> u256 {
  bb0:
    jumpi arg0, bb1, bb2
  bb1:
    v1 = sload 5
    jump bb3
  bb2:
    jump bb3
  bb3:
    v2 = sload 5
    ret v2
}

// CHECK-LABEL: {{^[ +].*}}fn @transient_store_forward{{[( ]}}
// CHECK: + [[MERGE:v[0-9]+]] = phi [bb1: arg1], [bb2: {{v[0-9]+}}]
// CHECK: + ret [[MERGE]]
fn @transient_store_forward(arg0: bool, arg1: u256) -> u256 {
  bb0:
    jumpi arg0, bb1, bb2
  bb1:
    tstore 5, arg1
    jump bb3
  bb2:
    v2 = tload 5
    jump bb3
  bb3:
    v3 = tload 5
    ret v3
}
