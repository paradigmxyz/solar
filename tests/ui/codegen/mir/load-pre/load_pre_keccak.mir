//@compile-flags: --pass load-pre
//@filecheck:
// Keccak reads key the canonical size operand when the size is not constant:
// reads with the same dynamic size unify across the join, reads with a
// different dynamic size share no key and are left alone.
@module LoadPreKeccak
// CHECK-LABEL: fn @keccak_same_dynamic_size
// CHECK: + [[MERGE:v[0-9]+]] = phi [bb1: {{v[0-9]+}}], [bb2: {{v[0-9]+}}]
// CHECK: + ret [[MERGE]]
fn @keccak_same_dynamic_size(arg0: bool, arg1: u256) -> u256 {
  bb0:
    br arg0, bb1, bb2
  bb1:
    v1 = keccak256 0, arg1
    jump bb3
  bb2:
    v2 = keccak256 0, arg1
    jump bb3
  bb3:
    v3 = keccak256 0, arg1
    ret v3
}

// CHECK-LABEL: fn @keccak_different_dynamic_size
// CHECK: [[JOIN:v[0-9]+]] = keccak256 0, arg2
// CHECK: ret [[JOIN]]
fn @keccak_different_dynamic_size(arg0: bool, arg1: u256, arg2: u256) -> u256 {
  bb0:
    br arg0, bb1, bb2
  bb1:
    v1 = keccak256 0, arg1
    jump bb3
  bb2:
    v2 = keccak256 0, arg1
    jump bb3
  bb3:
    v3 = keccak256 0, arg2
    ret v3
}
