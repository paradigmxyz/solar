//@compile-flags: --pass storage-promotion
//@filecheck:
@module StoragePromotion
// CHECK-LABEL: fn @promote_recomputed_offset_slot
// CHECK: + mstore 128, 1
// CHECK: + [[VALUE:v[0-9]+]] = mload 128
// CHECK: + [[FLUSH:v[0-9]+]] = mload 128
// CHECK: + sstore {{v[0-9]+}}, [[FLUSH]]
fn @promote_recomputed_offset_slot(arg0: u256) [selector=0x01020304] {
  bb0:
    v1 = add arg0, 1
    sstore v1, 1
    jump bb1
  bb1:
    br true, bb2, bb4
  bb2:
    v2 = add arg0, 1
    v3 = sload v2
    v4 = mul v3, 2
    v5 = add arg0, 1
    sstore v5, v4
    jump bb3
  bb3:
    jump bb1
  bb4:
    stop
}

// CHECK-LABEL: fn @reject_loop_variant_offset_slot
// CHECK: + [[VALUE:v[0-9]+]] = sload
// CHECK: + sstore
fn @reject_loop_variant_offset_slot(arg0: u256) [selector=0x01020304] {
  bb0:
    jump bb1
  bb1:
    v1 = phi [bb0: 0], [bb2: v6]
    br true, bb2, bb3
  bb2:
    v2 = add arg0, v1
    v3 = sload v2
    v4 = add v3, 2
    sstore v2, v4
    v6 = add v1, 1
    jump bb1
  bb3:
    stop
}

// CHECK-LABEL: fn @promote_store_only_without_initial_load
// CHECK: + mstore 128, 7
// CHECK: + [[VALUE:v[0-9]+]] = mload 128
// CHECK: + sstore 0, [[VALUE]]
fn @promote_store_only_without_initial_load() [selector=0x01020304] {
  bb0:
    jump bb1
  bb1:
    br true, bb2, bb4
  bb2:
    sstore 0, 7
    jump bb3
  bb3:
    jump bb1
  bb4:
    stop
}

// CHECK-LABEL: fn @promote_two_initialized_slots
// CHECK: + mstore 128, 1
// CHECK: + mstore 160, 2
// CHECK: + [[FIRST:v[0-9]+]] = mload 128
// CHECK: + [[SECOND:v[0-9]+]] = mload 160
fn @promote_two_initialized_slots() [selector=0x01020304] {
  bb0:
    sstore 0, 1
    sstore 1, 2
    jump bb1
  bb1:
    br true, bb2, bb4
  bb2:
    v1 = sload 0
    v2 = mul v1, 2
    sstore 0, v2
    v3 = sload 1
    v4 = add v3, 3
    sstore 1, v4
    jump bb3
  bb3:
    jump bb1
  bb4:
    stop
}

// CHECK-LABEL: fn @promote_without_init_rewrites_successor_phi
// CHECK: + mstore
// CHECK: + [[VALUE:v[0-9]+]] = phi
fn @promote_without_init_rewrites_successor_phi() -> u256 [selector=0x01020304] {
  bb0:
    jump bb1
  bb1:
    br true, bb2, bb4
  bb2:
    v1 = sload 0
    v2 = add v1, 2
    sstore 0, v2
    jump bb3
  bb3:
    jump bb1
  bb4:
    jump bb5
  bb5:
    v3 = phi [bb4: 7], [bb6: 9]
    ret v3
  bb6:
    jump bb5
}
