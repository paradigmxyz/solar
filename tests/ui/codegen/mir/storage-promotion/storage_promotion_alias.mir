//@compile-flags: --pass storage-promotion
//@filecheck: --check-prefix=CHECK --enable-var-scope
@module StoragePromotionAlias

// CHECK-LABEL: @reject_two_symbolic_slots
// CHECK: +     sstore arg0, 1
// CHECK: +     sstore arg1, 2
fn @reject_two_symbolic_slots(arg0: u256, arg1: u256) [selector=0x01020304] {
  bb0:
    sstore arg0, 1
    sstore arg1, 2
    jump bb1
  bb1:
    br true, bb2, bb4
  bb2:
    v1 = sload arg0
    v2 = mul v1, 2
    sstore arg0, v2
    v3 = sload arg1
    v4 = add v3, 3
    sstore arg1, v4
    jump bb3
  bb3:
    jump bb1
  bb4:
    stop
}

// CHECK-LABEL: @reject_symbolic_and_constant_slots
// CHECK: +     [[SYMBOLIC:v[0-9]+]] = sload arg0
// CHECK:       mul [[SYMBOLIC]], 2
// CHECK: +     [[CONSTANT:v[0-9]+]] = sload 7
// CHECK:       add [[CONSTANT]], 3
fn @reject_symbolic_and_constant_slots(arg0: u256) [selector=0x01020304] {
  bb0:
    sstore arg0, 1
    sstore 7, 2
    jump bb1
  bb1:
    br true, bb2, bb4
  bb2:
    v1 = sload arg0
    v2 = mul v1, 2
    sstore arg0, v2
    v3 = sload 7
    v4 = add v3, 3
    sstore 7, v4
    jump bb3
  bb3:
    jump bb1
  bb4:
    stop
}

// CHECK-LABEL: @promote_two_constant_slots
// CHECK: +     mstore 128, 1
// CHECK: +     mstore 160, 2
// CHECK:       bb4:
// CHECK: +     [[ONE:v[0-9]+]] = mload 160
// CHECK: +     sstore 1, [[ONE]]
// CHECK: +     [[ZERO:v[0-9]+]] = mload 128
// CHECK: +     sstore 0, [[ZERO]]
fn @promote_two_constant_slots() [selector=0x01020304] {
  bb0:
    sstore 0, 1
    sstore 1, 2
    jump bb1
  bb1:
    br true, bb2, bb4
  bb2:
    v1 = sload 0
    v2 = mul v1, 2
    sstore 0, v2
    v3 = sload 1
    v4 = add v3, 3
    sstore 1, v4
    jump bb3
  bb3:
    jump bb1
  bb4:
    stop
}

// CHECK-LABEL: @promote_same_base_distinct_offsets
// CHECK:       [[ONE_SLOT:v[0-9]+]] = add arg0, 1
// CHECK: +     mstore 128, 1
// CHECK:       [[TWO_SLOT:v[0-9]+]] = add arg0, 2
// CHECK: +     mstore 160, 2
// CHECK:       bb4:
// CHECK: +     [[TWO_VALUE:v[0-9]+]] = mload 160
// CHECK: +     sstore [[TWO_SLOT]], [[TWO_VALUE]]
// CHECK: +     [[ONE_VALUE:v[0-9]+]] = mload 128
// CHECK: +     sstore [[ONE_SLOT]], [[ONE_VALUE]]
fn @promote_same_base_distinct_offsets(arg0: u256) [selector=0x01020304] {
  bb0:
    v1 = add arg0, 1
    sstore v1, 1
    v2 = add arg0, 2
    sstore v2, 2
    jump bb1
  bb1:
    br true, bb2, bb4
  bb2:
    v3 = add arg0, 1
    v4 = sload v3
    v5 = mul v4, 2
    v6 = add arg0, 1
    sstore v6, v5
    v7 = add arg0, 2
    v8 = sload v7
    v9 = add v8, 3
    v10 = add arg0, 2
    sstore v10, v9
    jump bb3
  bb3:
    jump bb1
  bb4:
    stop
}
