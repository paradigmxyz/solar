// === ROOT/tests/ui/codegen/mir/jump_threading_phi_constants.mir (after jump-threading) ===
; module @JumpThreadingPhiConstants
fn @thread_branch_on_phi_constant(arg0: bool) -> u256 {
  bb0 (entry):
    br arg0, bb5, bb4
  bb1:
    jump bb5
  bb2:
    jump bb4
  bb3:
    v3 = phi
    br v3, bb4, bb5
  bb4:
    ret 11
  bb5:
    ret 22
}

fn @thread_switch_on_phi_constant(arg0: bool) -> u256 {
  bb0 (entry):
    br arg0, bb4, bb5
  bb1:
    jump bb4
  bb2:
    jump bb5
  bb3:
    v3 = phi
    switch v3, default bb6, [1 => bb4, 2 => bb5]
  bb4:
    ret 11
  bb5:
    ret 22
  bb6:
    ret 33
}

fn @keep_unknown_phi(arg0: bool, arg1: u256, arg2: u256) -> u256 {
  bb0 (entry):
    br arg0, bb1, bb2
  bb1:
    jump bb3
  bb2:
    jump bb3
  bb3:
    v3 = phi [bb1: arg1], [bb2: arg2]
    br v3, bb4, bb5
  bb4:
    ret 11
  bb5:
    ret 22
}

fn @keep_phi_used_in_successor(arg0: bool) -> u256 {
  bb0 (entry):
    br arg0, bb1, bb2
  bb1:
    jump bb3
  bb2:
    jump bb3
  bb3:
    v3 = phi [bb1: 0], [bb2: 1]
    br v3, bb4, bb5
  bb4:
    v5 = add v3, 1
    ret v5
  bb5:
    ret 22
}
