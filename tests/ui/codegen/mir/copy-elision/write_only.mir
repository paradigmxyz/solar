//@compile-flags: --passes copy-elision,dce
//@filecheck:
@module CopyElision

// An allocation filled by a copy but never read is dead: the copy and the
// allocation are removed.
// CHECK-LABEL: fn @unread
// CHECK: - {{v[0-9]+}} = alloc memorybytes, exact, uninitialized, infallible, 64
// CHECK: - calldatacopy {{v[0-9]+}}, 4, 32
fn @unread(arg0: u256) -> u256 {
  bb0:
    v0 = alloc memorybytes, exact, uninitialized, infallible, 64
    v1 = memory_object_data memorybytes, v0
    calldatacopy v1, 4, 32
    ret arg0
}

// A read of the allocation keeps every write.
// CHECK-LABEL: fn @read
// CHECK: {{v[0-9]+}} = alloc memorybytes, exact, uninitialized, infallible, 64
// CHECK: calldatacopy {{v[0-9]+}}, 4, 32
fn @read(arg0: u256) -> u256 {
  bb0:
    v0 = alloc memorybytes, exact, uninitialized, infallible, 64
    v1 = memory_object_data memorybytes, v0
    calldatacopy v1, 4, 32
    v2 = mload v1
    ret v2
}
