//@compile-flags: --pass dce
// Side-effect instructions must survive DCE even if their results are unused.
// sstore, log0, call all have side effects.
@module DceSideEffects
fn @effects(arg0: u256, arg1: u256) {
  bb0 (entry):
    sstore arg0, arg1
    log0 0, 32
    v1 = add arg0, arg1
    stop
}
