//@compile-flags: --pass dce
//@filecheck:
// bb1 is unreachable (entry jumps straight to bb2).
// DCE should clear bb1's instructions and mark it invalid.
@module DceUnreachable
// CHECK-LABEL: fn @skip
// CHECK: bb1:
// CHECK: - {{v[0-9]+}} = add arg0, 1
// CHECK: - {{v[0-9]+}} = mul {{v[0-9]+}}, {{v[0-9]+}}
// CHECK: - ret {{v[0-9]+}}
// CHECK: + invalid
fn @skip(arg0: u256) -> u256 {
  bb0:
    jump bb2
  bb1:
    v1 = add arg0, 1
    v2 = mul v1, v1
    ret v2
  bb2:
    ret arg0
}
