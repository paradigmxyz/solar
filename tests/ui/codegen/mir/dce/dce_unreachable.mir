//@compile-flags: --pass dce -Ztime-passes
//@filecheck: --match-full-lines
//@normalize-stderr-test: "time: +[0-9]+\.[0-9]{3}" -> "time: <TIME>"
// bb1 is unreachable (entry jumps straight to bb2).
// DCE should clear bb1's instructions and mark it invalid.
@module DceUnreachable
// CHECK-LABEL:   fn @skip(arg0: u256) -> u256 {
// CHECK:       bb1:
// CHECK: +     invalid
fn @skip(arg0: u256) -> u256 {
  bb0:
    jump bb2
  bb1:
    v1 = add arg0, 1
    v2 = mul v1, v1
    ret v2
  bb2:
    ret arg0
}
