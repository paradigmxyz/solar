//@compile-flags: --pipeline-default
//@filecheck:
@module PipelineDefault
// CHECK-LABEL: fn @noisy{{[( ]}}
// CHECK: bb0:
// CHECK: [[RESULT:v[0-9]+]] = add arg0, 1
// CHECK: ret [[RESULT]]
fn @noisy(arg0: u256) -> u256 {
  bb0:
    v1 = add arg0, 1
    v2 = mul arg0, arg0
    jump bb1
  bb1:
    jump bb2
  bb2:
    ret v1
}
