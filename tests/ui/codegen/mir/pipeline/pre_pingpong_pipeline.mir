//@compile-flags: --pipeline-default
//@filecheck: --implicit-check-not=add
// Same shape as pre_pingpong.mir: the full default pipeline must terminate on
// joins that are mutual predecessors.
@module PingPongPipeline
// CHECK-LABEL: fn @pingpong{{[( ]}}
// CHECK: bb0:
// CHECK: jump bb6
// CHECK: bb6:
// CHECK: jump bb6
fn @pingpong(arg0: u256, arg1: u256) {
  bb0:
    switch arg1, default bb1, [1 => bb2, 2 => bb3, 3 => bb4]
  bb1:
    v2 = add arg0, 7
    jump bb5
  bb2:
    v3 = add arg0, 7
    jump bb5
  bb3:
    v4 = add arg0, 7
    jump bb6
  bb4:
    v5 = add arg0, 7
    jump bb6
  bb5:
    v6 = add arg0, 7
    jump bb6
  bb6:
    jump bb5
}
