//@compile-flags: --passes cse,memory-dse,storage-load-cse,storage-dse,dce
//@filecheck:
@module AggregateEffects

// CSE forwards across aggregate effects only when their ranges are disjoint.
// CHECK: + // === {{.*}} (after cse) ===
// CHECK: fn @flat_memory_write_is_precise
// CHECK: - {{v[0-9]+}} = mload 128
// CHECK: + {{v[0-9]+}} = add [[FLAT:v[0-9]+]], [[FLAT]]
// CHECK: fn @nested_memory_write_is_barrier
// CHECK: {{v[0-9]+}} = mload 128
// CHECK: {{v[0-9]+}} = mload 128
// CHECK: fn @disjoint_storage
// CHECK: + {{v[0-9]+}} = add [[SLOAD:v[0-9]+]], [[SLOAD]]
// CHECK: fn @overlapping_storage
// CHECK: {{v[0-9]+}} = sload 0
// CHECK: {{v[0-9]+}} = sload 0
// Aggregate writes kill preceding stores only when they overwrite the value.
// CHECK: + // === {{.*}} (after memory-dse) ===
// CHECK: fn @overwrites_memory
// CHECK: - mstore arg0, 7
// CHECK: + // === {{.*}} (after storage-dse) ===
// CHECK: fn @clobbers_stored_value
// CHECK: - sstore 0, 1 !metadata(storage=slot(0))

fn @reads_memory(arg0: memptr) {
  bb0:
    mstore arg0, 7
    memory_to_storage struct<word>, arg0, 0
    stop
}

fn @overwrites_memory(arg0: memptr) -> u256 {
  bb0:
    mstore arg0, 7
    storage_to_memory struct<word>, 0, arg0
    v0 = mload arg0
    ret v0
}

fn @flat_memory_write_is_precise() -> u256 {
  bb0:
    v0 = mload 128
    storage_to_memory struct<word>, 0, 256
    v1 = mload 128
    v2 = add v0, v1
    ret v2
}

fn @nested_memory_write_is_barrier() -> u256 {
  bb0:
    v0 = mload 128
    storage_to_memory struct<struct<word>>, 0, 256
    v1 = mload 128
    v2 = add v0, v1
    ret v2
}

fn @disjoint_storage() -> u256 {
  bb0:
    v0 = sload 0
    clear_storage struct<word, word>, 10
    v1 = sload 0
    v2 = add v0, v1
    ret v2
}

fn @overlapping_storage() -> u256 {
  bb0:
    v0 = sload 0
    clear_storage struct<word, word>, 0
    v1 = sload 0
    v2 = add v0, v1
    ret v2
}

fn @observes_storage(arg0: memptr) {
  bb0:
    sstore 0, 1
    storage_to_memory struct<word>, 0, arg0
    sstore 0, 2
    stop
}

fn @clobbers_stored_value() {
  bb0:
    sstore 0, 1
    clear_storage struct<word>, 0
    sstore 0, 1
    stop
}
