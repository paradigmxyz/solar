//@compile-flags: --passes jump-threading,cfg-simplify,dce
//@filecheck:
// Jump threading and CFG simplification expose the multiplication as dead.
@module Pipeline
// CHECK-LABEL: fn @noisy
// CHECK: - jump bb1
// CHECK: + jump bb2
// CHECK: - jump bb2
// CHECK: + ret {{v[0-9]+}}
// CHECK: - {{v[0-9]+}} = mul arg0, arg0
fn @noisy(arg0: u256) -> u256 {
  bb0:
    v1 = add arg0, 1
    v2 = mul arg0, arg0
    jump bb1
  bb1:
    jump bb2
  bb2:
    ret v1
}
