// === ROOT/tests/ui/codegen/mir/frame_promotion_sequential_counter.mir (after frame-slot-promotion,cfg-simplify,dce) ===
@module SequentialCounter
fn @sequential(arg0: u256) -> u256 {
  bb0 (entry):
    jump bb1
  bb1:
    v27 = phi [bb0: 0], [bb2: v7]
    v29 = phi [bb0: 0], [bb2: v11]
    v4 = lt v29, arg0
    br v4, bb2, bb3
  bb2:
    v7 = add v27, 1
    v11 = add v29, 1
    jump bb1
  bb3:
    jump bb4
  bb4:
    v28 = phi [bb3: v27], [bb5: v19]
    v30 = phi [bb3: 0], [bb5: v23]
    v16 = lt v30, arg0
    br v16, bb5, bb6
  bb5:
    v19 = add v28, 1
    v23 = add v30, 1
    jump bb4
  bb6:
    ret v28
}
