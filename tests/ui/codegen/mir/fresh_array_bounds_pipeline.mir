//@compile-flags: --pipeline-default
@module FreshArrayBoundsPipeline

// This is the MIR shape produced by `uint256[] memory x = new uint256[](3); x[1]`:
// the length store is separated from the length load by an FMP update and a
// zeroing calldatacopy over the data area. The default pipeline should forward
// the stored length, fold `1 < 3`, and delete the panic branch.
fn @constant_index() -> u256 {
  bb0 (entry):
    v0 = mload 64
    mstore v0, 3
    v1 = add v0, 128
    mstore 64, v1
    v2 = add v0, 32
    calldatacopy v2, 0, 96
    v3 = mload v0
    v4 = lt 1, v3
    br v4, bb2, bb1
  bb1:
    revert 0, 36
  bb2:
    ret 7
}

// Runtime lengths still need the bounds branch.
fn @runtime_index(arg0: u256) -> u256 {
  bb0 (entry):
    v0 = mload 64
    mstore v0, arg0
    v1 = shl 5, arg0
    v2 = add v1, 32
    v3 = add v0, v2
    mstore 64, v3
    v4 = add v0, 32
    calldatacopy v4, 0, v1
    v5 = mload v0
    v6 = lt 1, v5
    br v6, bb2, bb1
  bb1:
    revert 0, 36
  bb2:
    ret 7
}
