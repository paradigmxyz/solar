// === ROOT/tests/ui/codegen/mir/load_pre.mir (after load-pre) ===
; module @LoadPre
fn @full_diamond(arg0: bool) -> u256 {
  bb0 (entry):
    br arg0, bb1, bb2
  bb1:
    v2 = sload 5
    jump bb3
  bb2:
    v4 = sload 5
    jump bb3
  bb3:
    v7 = phi [bb1: v2], [bb2: v4]
    ret v7
}

fn @store_forward_arm(arg0: bool, arg1: u256) -> u256 {
  bb0 (entry):
    br arg0, bb1, bb2
  bb1:
    sstore 5, arg1
    jump bb3
  bb2:
    v4 = sload 5
    jump bb3
  bb3:
    v7 = phi [bb1: arg1], [bb2: v4]
    ret v7
}

fn @partial_insert_diamond(arg0: bool) -> u256 {
  bb0 (entry):
    br arg0, bb1, bb2
  bb1:
    v2 = sload 5
    jump bb3
  bb2:
    v5 = sload 5
    jump bb3
  bb3:
    v6 = phi [bb1: v2], [bb2: v5]
    ret v6
}

fn @transient_store_forward(arg0: bool, arg1: u256) -> u256 {
  bb0 (entry):
    br arg0, bb1, bb2
  bb1:
    tstore 5, arg1
    jump bb3
  bb2:
    v4 = tload 5
    jump bb3
  bb3:
    v7 = phi [bb1: arg1], [bb2: v4]
    ret v7
}
