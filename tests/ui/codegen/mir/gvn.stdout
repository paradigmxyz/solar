// === ROOT/tests/ui/codegen/mir/gvn.mir (after gvn) ===
; module @Gvn
fn @transitive_congruence(arg0: u256, arg1: u256) -> u256 {
  bb0 (entry):
    v2 = add arg0, arg1
    v5 = mul v2, 2
    v8 = add v5, v5
    ret v8
}

fn @equal_immediates_unify(arg0: u256) -> u256 {
  bb0 (entry):
    v2 = add arg0, 16
    v5 = add v2, v2
    ret v5
}

fn @swapped_comparison_feeds_arithmetic(arg0: u256, arg1: u256) -> u256 {
  bb0 (entry):
    v2 = lt arg0, arg1
    v4 = select v2, arg0, arg1
    v6 = add v4, v4
    ret v6
}

fn @keep_state_dependent_reads(arg0: u256) -> u256 {
  bb0 (entry):
    v1 = sload arg0
    v2 = sload arg0
    v3 = balance arg0
    v4 = balance arg0
    v7 = keccak256 0, 32
    v10 = keccak256 0, 32
    v11 = add v1, v2
    v12 = add v3, v4
    v13 = add v7, v10
    v14 = add v11, v12
    v15 = add v14, v13
    ret v15
}

fn @no_replacement_across_siblings(arg0: u256, arg1: bool) -> u256 {
  bb0 (entry):
    br arg1, bb1, bb2
  bb1:
    v3 = add arg0, 1
    v5 = mul v3, 3
    jump bb3
  bb2:
    v7 = add arg0, 1
    v9 = mul v7, 3
    jump bb3
  bb3:
    v10 = phi [bb1: v5], [bb2: v9]
    ret v10
}
