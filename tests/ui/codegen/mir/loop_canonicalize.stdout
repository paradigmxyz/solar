// === ROOT/tests/ui/codegen/mir/loop_canonicalize.mir (after loop-canonicalize) ===
@module LoopCanonicalize
fn @insert_preheader(arg0: bool) -> u256 {
  bb0 (entry):
    br arg0, bb1, bb2
  bb1:
    jump bb6
  bb2:
    jump bb6
  bb3:
    v0 = phi [bb4: 30], [bb6: v1]
    br 1, bb4, bb5
  bb4:
    jump bb3
  bb5:
    ret v0
  bb6:
    v1 = phi [bb1: 10], [bb2: 20]
    jump bb3
}

fn @split_conditional_predecessor(arg0: bool) -> u256 {
  bb0 (entry):
    br arg0, bb4, bb3
  bb1:
    v0 = phi [bb2: 1], [bb4: 0]
    br 1, bb2, bb3
  bb2:
    jump bb1
  bb3:
    ret 0
  bb4:
    jump bb1
}
