// === ROOT/tests/ui/codegen/mir/licm_loop_bound.mir (after licm) ===
; module @LicmLoopBound
fn @keep_mload_non_exiting_bound() -> u256 {
  bb0 (entry):
    jump bb1
  bb1:
    v2 = phi [bb0: 0], [bb4: v1]
    v4 = eq v2, 100
    br v4, bb5, bb2
  bb2:
    v6 = mload 64
    v8 = mul v2, 32
    mstore v8, 1
    v11 = lt v2, 2
    br v11, bb3, bb4
  bb3:
    jump bb4
  bb4:
    v1 = add v2, 1
    jump bb1
  bb5:
    ret v6
}

fn @keep_mload_inner_branch_bound() -> u256 {
  bb0 (entry):
    jump bb1
  bb1:
    v2 = phi [bb0: 0], [bb4: v1]
    v4 = lt v2, 100
    br v4, bb2, bb5
  bb2:
    v6 = mload 64
    v8 = mul v2, 32
    mstore v8, 1
    v11 = lt v2, 2
    br v11, bb3, bb4
  bb3:
    jump bb4
  bb4:
    v1 = add v2, 1
    jump bb1
  bb5:
    ret v6
}
