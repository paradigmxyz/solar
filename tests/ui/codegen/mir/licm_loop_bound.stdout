// === ROOT/tests/ui/codegen/mir/licm_loop_bound.mir (after licm) ===
@module LicmLoopBound
fn @keep_mload_non_exiting_bound() -> u256 {
  bb0 (entry):
    jump bb1
  bb1:
    v0 = phi [bb0: 0], [bb4: v5]
    v1 = eq v0, 100
    br v1, bb5, bb2
  bb2:
    v2 = mload 64
    v3 = mul v0, 32
    mstore v3, 1
    v4 = lt v0, 2
    br v4, bb3, bb4
  bb3:
    jump bb4
  bb4:
    v5 = add v0, 1
    jump bb1
  bb5:
    ret v2
}

fn @keep_mload_inner_branch_bound() -> u256 {
  bb0 (entry):
    jump bb1
  bb1:
    v0 = phi [bb0: 0], [bb4: v5]
    v1 = lt v0, 100
    br v1, bb2, bb5
  bb2:
    v2 = mload 64
    v3 = mul v0, 32
    mstore v3, 1
    v4 = lt v0, 2
    br v4, bb3, bb4
  bb3:
    jump bb4
  bb4:
    v5 = add v0, 1
    jump bb1
  bb5:
    ret v2
}
