//@compile-flags: --pass cfg-simplify
//@filecheck:
// Both arms of the entry branch are empty forwarders into the same join.
// Eliminating both would give the join phi two entries for bb0 with
// conflicting values, so at most one forwarder may be folded away.
@module CfgSimplifyPhiForwarders
// CHECK-LABEL: {{^[ +].*}}fn @keep_conflicting_diamond{{[( ]}}
// CHECK: + jumpi arg0, [[JOIN:bb[0-9]+]], [[FORWARDER:bb[0-9]+]]
// CHECK: + jump [[JOIN]]
// CHECK: + {{v[0-9]+}} = phi [bb0: 1], [[[FORWARDER]]: 2]
fn @keep_conflicting_diamond(arg0: bool) -> u256 {
  bb0:
    jumpi arg0, bb1, bb2
  bb1:
    jump bb3
  bb2:
    jump bb3
  bb3:
    v3 = phi [bb1: 1], [bb2: 2]
    ret v3
}

// With equal incoming values the forwarders can both collapse; the phi
// keeps a single entry per predecessor.
// CHECK-LABEL: {{^[ +].*}}fn @fold_equal_value_diamond{{[( ]}}
// CHECK: + jumpi arg0, [[EQUAL_JOIN:bb[0-9]+]], [[EQUAL_FORWARDER:bb[0-9]+]]
// CHECK: + jump [[EQUAL_JOIN]]
// CHECK: + {{v[0-9]+}} = phi [bb0: 7], [[[EQUAL_FORWARDER]]: 7]
fn @fold_equal_value_diamond(arg0: bool) -> u256 {
  bb0:
    jumpi arg0, bb1, bb2
  bb1:
    jump bb3
  bb2:
    jump bb3
  bb3:
    v3 = phi [bb1: 7], [bb2: 7]
    ret v3
}
