//@compile-flags: --pass cfg-simplify
// Two trivial phis forming a chain across nested loops: v2's unique source is
// v1, itself a trivial phi deleted in the same batch. Uses of v2 must resolve
// through the chain to arg0, not to the deleted intermediate.
@module CfgSimplifyTrivialPhiChain
fn @chained_trivial(arg0: u256) -> u256 {
  bb0:
    jump bb1
  bb1:
    v1 = phi [bb0: arg0], [bb3: v1]
    jumpi arg0, bb2, bb4
  bb2:
    v2 = phi [bb1: v1], [bb2: v2]
    v3 = add v2, 1
    jumpi v3, bb2, bb3
  bb3:
    jump bb1
  bb4:
    ret v1
}
