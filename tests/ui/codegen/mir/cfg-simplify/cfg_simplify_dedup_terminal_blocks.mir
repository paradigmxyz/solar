//@compile-flags: --pass cfg-simplify
//@filecheck:
@module CfgDedupTerminalBlocks

// Two structurally identical panic blocks collapse into one shared block.
// CHECK-LABEL: {{^[ +].*}}fn @dedup_identical_panics{{[( ]}}
// CHECK: - br arg1, bb3, bb4
// CHECK: + br arg1, bb1, bb4
fn @dedup_identical_panics(arg0: u256, arg1: u256) {
  bb0:
    br arg0, bb1, bb2
  bb1:
    mstore 0, 0x4e487b7100000000000000000000000000000000000000000000000000000000
    mstore 4, 17
    revert 0, 36
  bb2:
    br arg1, bb3, bb4
  bb3:
    mstore 0, 0x4e487b7100000000000000000000000000000000000000000000000000000000
    mstore 4, 17
    revert 0, 36
  bb4:
    stop
}

// Panic blocks with different panic codes must NOT merge.
// CHECK-LABEL: {{^[ +].*}}fn @keep_distinct_panic_codes{{[( ]}}
// CHECK: {{^[ +].*}}br arg1, bb3, bb4
fn @keep_distinct_panic_codes(arg0: u256, arg1: u256) {
  bb0:
    br arg0, bb1, bb2
  bb1:
    mstore 0, 0x4e487b7100000000000000000000000000000000000000000000000000000000
    mstore 4, 17
    revert 0, 36
  bb2:
    br arg1, bb3, bb4
  bb3:
    mstore 0, 0x4e487b7100000000000000000000000000000000000000000000000000000000
    mstore 4, 18
    revert 0, 36
  bb4:
    stop
}

// Identical instructions but different terminator operands must NOT merge.
// CHECK-LABEL: {{^[ +].*}}fn @keep_distinct_revert_sizes{{[( ]}}
// CHECK: {{^[ +].*}}br arg1, bb3, bb4
fn @keep_distinct_revert_sizes(arg0: u256, arg1: u256) {
  bb0:
    br arg0, bb1, bb2
  bb1:
    mstore 0, 0x4e487b7100000000000000000000000000000000000000000000000000000000
    mstore 4, 17
    revert 0, 36
  bb2:
    br arg1, bb3, bb4
  bb3:
    mstore 0, 0x4e487b7100000000000000000000000000000000000000000000000000000000
    mstore 4, 17
    revert 0, 32
  bb4:
    stop
}

// Block-local values compare by definition position, so alpha-equivalent
// computations merge.
// CHECK-LABEL: {{^[ +].*}}fn @dedup_local_computations{{[( ]}}
// CHECK: - br arg1, bb3, bb4
// CHECK: + br arg1, bb1, bb4
fn @dedup_local_computations(arg0: u256, arg1: u256) {
  bb0:
    br arg0, bb1, bb2
  bb1:
    v10 = add arg0, 1
    mstore 0, v10
    revert 0, 32
  bb2:
    br arg1, bb3, bb4
  bb3:
    v20 = add arg0, 1
    mstore 0, v20
    revert 0, 32
  bb4:
    stop
}

// Blocks reading different outside values must NOT merge.
// CHECK-LABEL: {{^[ +].*}}fn @keep_distinct_outside_operands{{[( ]}}
// CHECK: {{^[ +].*}}br arg1, bb3, bb4
fn @keep_distinct_outside_operands(arg0: u256, arg1: u256) {
  bb0:
    br arg0, bb1, bb2
  bb1:
    mstore 0, arg0
    revert 0, 32
  bb2:
    br arg1, bb3, bb4
  bb3:
    mstore 0, arg1
    revert 0, 32
  bb4:
    stop
}
