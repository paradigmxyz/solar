//@compile-flags: --pass cfg-simplify
//@filecheck:
@module CfgSimplify
// CHECK-LABEL: {{^[ +].*}}fn @sequential{{[( ]}}
// CHECK: {{^[ +].*}}{{v[0-9]+}} = add arg0, 1
// CHECK: {{^[ +].*}}{{v[0-9]+}} = add {{v[0-9]+}}, 1
// CHECK: {{^[ +].*}}{{v[0-9]+}} = add {{v[0-9]+}}, 1
// CHECK: {{^[ +].*}}ret {{v[0-9]+}}
fn @sequential(arg0: u256) -> u256 {
  bb0:
    v1 = add arg0, 1
    jump bb1
  bb1:
    v2 = add v1, 1
    jump bb2
  bb2:
    v3 = add v2, 1
    ret v3
}

// CHECK-LABEL: {{^[ +].*}}fn @branch_forwarder_preserves_successor_order{{[( ]}}
// CHECK: - jump bb3
fn @branch_forwarder_preserves_successor_order(arg0: bool) -> u256 {
  bb0:
    br arg0, bb1, bb2
  bb1:
    ret 1
  bb2:
    jump bb3
  bb3:
    ret 2
}

// CHECK-LABEL: {{^[ +].*}}fn @degenerate_branch_refreshes_successors{{[( ]}}
// CHECK: - br arg0, bb1, bb1
fn @degenerate_branch_refreshes_successors(arg0: bool) -> u256 {
  bb0:
    br arg0, bb1, bb1
  bb1:
    ret 1
}
