//@compile-flags: --pass dce
//@failure-status: 1
// EVM-shaped MIR is the word-backend boundary. Semantic memory operations
// must be rejected here if their named lowering pass did not consume them.
@module ValidateMemoryBoundary
@phase evm-shaped
fn @slice(arg0: memptr, arg1: u256) -> u256 {
  bb0 (entry):
    v2 = make_memory_slice arg0, arg1
    v3 = slice_len v2
    ret v3
}
fn @abi(arg0: u256) -> memoryslice {
  bb0 (entry):
    v1 = abi_encode [word], args arg0
    ret v1
}
fn @aggregate(arg0: u256, arg1: memorystruct) {
  bb0 (entry):
    storage_to_memory struct<word>, arg0, arg1
    stop
}
