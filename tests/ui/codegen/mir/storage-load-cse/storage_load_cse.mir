//@compile-flags: --pass storage-load-cse
//@filecheck:
@module StorageLoadCse
// CHECK-LABEL: fn @reuse_across_disjoint_constant_store
// CHECK: + [[LOAD:v[0-9]+]] = sload 0
// CHECK: + {{v[0-9]+}} = add [[LOAD]], [[LOAD]]
fn @reuse_across_disjoint_constant_store() -> u256 {
  bb0:
    v1 = sload 0
    sstore 1, 9
    v2 = sload 0
    v3 = add v1, v2
    ret v3
}

// CHECK-LABEL: fn @keep_after_same_slot_store
// CHECK: + {{v[0-9]+}} = sload 0
// CHECK: + sstore 0, 9
// CHECK: + {{v[0-9]+}} = sload 0
fn @keep_after_same_slot_store() -> u256 {
  bb0:
    v1 = sload 0
    sstore 0, 9
    v2 = sload 0
    v3 = add v1, v2
    ret v3
}

// CHECK-LABEL: fn @keep_after_symbolic_store
// CHECK: + {{v[0-9]+}} = sload 0
// CHECK: + sstore arg0, 9
// CHECK: + {{v[0-9]+}} = sload 0
fn @keep_after_symbolic_store(arg0: u256) -> u256 {
  bb0:
    v1 = sload 0
    sstore arg0, 9
    v2 = sload 0
    v3 = add v1, v2
    ret v3
}

// CHECK-LABEL: fn @reuse_across_disjoint_offset_store
// CHECK: + [[LOAD:v[0-9]+]] = sload
// CHECK: + {{v[0-9]+}} = add [[LOAD]], [[LOAD]]
fn @reuse_across_disjoint_offset_store(arg0: u256) -> u256 {
  bb0:
    v1 = add arg0, 1
    v2 = sload v1
    v3 = add arg0, 2
    sstore v3, 9
    v4 = add arg0, 1
    v5 = sload v4
    v6 = add v2, v5
    ret v6
}

// CHECK-LABEL: fn @keep_when_reuse_extends_live_range
// CHECK: + {{v[0-9]+}} = sload 0
// CHECK: + [[SECOND:v[0-9]+]] = sload 0
// CHECK: ret [[SECOND]]
fn @keep_when_reuse_extends_live_range() -> u256 {
  bb0:
    v1 = sload 0
    sstore 1, 9
    v2 = sload 0
    ret v2
}

// CHECK-LABEL: fn @replace_uses_after_second_load
// CHECK: - {{.*}}sload 0
// CHECK: + {{v[0-9]+}} = add [[LOAD:v[0-9]+]], [[LOAD]]
// CHECK: phi [bb0: [[LOAD]]]
fn @replace_uses_after_second_load() -> u256 {
  bb0:
    v1 = sload 0
    v2 = sload 0
    v3 = add v1, v2
    jump bb1
  bb1:
    v4 = phi [bb0: v2]
    v5 = add v3, v4
    ret v5
}
