//@compile-flags: --pass lower-abi,lower-dispatch
// The two lowering phases compose: ABI first materializes self-decoding
// wrappers, then dispatch routes a selector switch to those argument-free
// wrappers. The module ends in the `dispatch` phase.
@module LowerAbiThenDispatch
fn @get(arg0: u256) [selector=0x9507d39a] {
  bb0 (entry):
    mstore 128, arg0
    returndata 128, 32
}
