// === ROOT/tests/ui/codegen/mir/gvn_phi.mir (after gvn) ===
; module @GvnPhi
fn @congruent_phis_collapse(arg0: u256, arg1: u256, arg2: bool) -> u256 {
  bb0 (entry):
    br arg2, bb1, bb2
  bb1:
    jump bb3
  bb2:
    jump bb3
  bb3:
    v3 = phi [bb1: arg0], [bb2: arg1]
    v5 = add v3, v3
    ret v5
}

fn @phi_of_same_folds_to_dominating_operand(arg0: u256, arg1: bool) -> u256 {
  bb0 (entry):
    v3 = add arg0, 1
    br arg1, bb1, bb2
  bb1:
    jump bb3
  bb2:
    jump bb3
  bb3:
    v6 = mul v3, 2
    ret v6
}

fn @phi_of_congruent_incoming(arg0: u256, arg1: bool) -> u256 {
  bb0 (entry):
    v3 = add arg0, 1
    br arg1, bb1, bb2
  bb1:
    jump bb3
  bb2:
    jump bb3
  bb3:
    ret v3
}

fn @phi_of_equal_immediates(arg0: bool) -> u256 {
  bb0 (entry):
    br arg0, bb1, bb2
  bb1:
    jump bb3
  bb2:
    jump bb3
  bb3:
    ret 7
}

fn @lockstep_loop_phis_stay(arg0: u256) -> u256 {
  bb0 (entry):
    jump bb1
  bb1:
    v3 = phi [bb0: 0], [bb2: v2]
    v6 = phi [bb0: 0], [bb2: v5]
    v7 = lt v3, arg0
    br v7, bb2, bb3
  bb2:
    v2 = add v3, 1
    v5 = add v6, 1
    jump bb1
  bb3:
    v10 = add v3, v6
    ret v10
}
