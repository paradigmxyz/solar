//@compile-flags: --pass none
//@filecheck:
@module PhiTest
// CHECK-LABEL: {{^[ +].*}}fn @diamond{{[( ]}}
// CHECK: {{^[ +].*}}[[VALUE:v[0-9]+]] = phi [bb1: 10], [bb2: 20]
// CHECK: {{^[ +].*}}ret [[VALUE]]
fn @diamond(arg0: bool) -> u256 {
  bb0:
    br arg0, bb1, bb2
  bb1:
    jump bb3
  bb2:
    jump bb3
  bb3:
    v1 = phi [bb1: 10], [bb2: 20]
    ret v1
}
