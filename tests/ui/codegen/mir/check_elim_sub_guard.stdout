// === ROOT/tests/ui/codegen/mir/check_elim_sub_guard.mir (after check-elim) ===
; module @CheckElimSubGuard
fn @fold_sub_after_ge_guard(arg0: u256, arg1: u256) -> u256 {
  bb0 (entry):
    v2 = gt arg1, arg0
    v3 = iszero v2
    v4 = iszero v3
    br v4, bb1, bb2
  bb1:
    revert 0, 0
  bb2:
    v7 = sub arg0, arg1
    v8 = lt arg0, arg1
    jump bb4
  bb3:
    revert 0, 0
  bb4:
    ret v7
}

fn @keep_sub_without_guard(arg0: u256, arg1: u256) -> u256 {
  bb0 (entry):
    v2 = sub arg0, arg1
    v3 = lt arg0, arg1
    br v3, bb1, bb2
  bb1:
    revert 0, 0
  bb2:
    ret v2
}

fn @keep_sub_on_other_value(arg0: u256, arg1: u256) -> u256 {
  bb0 (entry):
    v2 = gt arg1, arg0
    br v2, bb1, bb2
  bb1:
    revert 0, 0
  bb2:
    v6 = mload 0
    v7 = sub v6, arg1
    v8 = lt v6, arg1
    br v8, bb3, bb4
  bb3:
    revert 0, 0
  bb4:
    ret v7
}
