//@compile-flags: --pass lower-memory-objects
//@filecheck:
@module LowerMemoryObjects
@phase dispatch

// CHECK-LABEL: fn @objects
// CHECK: + [[OBJECT:v[0-9]+]] = alloc raw
// CHECK: + mstore [[OBJECT]], 3
// CHECK: + [[LENGTH:v[0-9]+]] = mload [[OBJECT]]
// CHECK: + [[DATA:v[0-9]+]] = add [[OBJECT]], 32
fn @objects(arg0: memorybytes, arg1: memoryarray, arg2: memorystruct, arg3: memoryfixedarray) {
  bb0:
    v4 = alloc memorybytes, exact, zeroed, panic, 96
    set_memory_object_len memorybytes, v4, 3
    v5 = memory_object_len memorybytes, v4
    v6 = memory_object_data memorybytes, v4
    mstore8 v6, v5
    v7 = memory_object_field_addr memorystruct<2>, arg2, 1
    mstore v7, v5
    v8 = memory_object_element_addr memoryarray<1>, arg1, v5
    mstore v8, v5
    v9 = memory_object_element_addr memoryfixedarray<4, 1>, arg3, v5
    mstore v9, v5
    stop
}
