// === ROOT/tests/ui/codegen/mir/lower_dispatch_parity.mir (after lower-dispatch) ===
@module DispatchParity
@phase dispatch
fn @pay() {
  bb0 (entry):
    stop
}

fn @nopay() {
  bb0 (entry):
    stop
}

fn @recv() {
  bb0 (entry):
    stop
}

fn @fb() {
  bb0 (entry):
    stop
}

fn @entry() {
  bb0 (entry):
    jump bb1
  bb1:
    v0 = calldatasize
    br v0, bb3, bb2
  bb2:
    tail_call @recv
  bb3:
    v1 = calldataload 0
    v2 = shr 224, v1
    switch v2, default bb6, [1 => bb4, 2 => bb5]
  bb4:
    tail_call @pay
  bb5:
    tail_call @nopay
  bb6:
    tail_call @fb
  bb7:
    revert 0, 0
}
