//@compile-flags: --pass outline-reverts
//@filecheck:
// Two functions carry the same constant panic block; it is outlined into one
// shared no-return helper and each site becomes an argless `tail_call` — a
// bare jump in the backend. The distinct panic in `@third` stays inline: a
// shape must occur at least twice to pay for the helper.

@module OutlineReverts

// CHECK-LABEL: {{^[ +].*}}fn @first{{[( ]}}
// CHECK: + tail_call @[[STUB:__revert_stub[0-9]+]]
fn @first(arg0: u256) {
  bb0:
    v1 = add arg0, 1
    v2 = lt v1, arg0
    br v2, bb1, bb2
  bb1:
    mstore 0, 0x4e487b7100000000000000000000000000000000000000000000000000000000
    mstore 4, 17
    revert 0, 36
  bb2:
    mstore 128, v1
    returndata 128, 32
}

// CHECK-LABEL: {{^[ +].*}}fn @second{{[( ]}}
// CHECK: + tail_call @[[STUB]]
fn @second(arg0: u256) {
  bb0:
    v1 = mul arg0, 2
    v2 = lt v1, arg0
    br v2, bb1, bb2
  bb1:
    mstore 0, 0x4e487b7100000000000000000000000000000000000000000000000000000000
    mstore 4, 17
    revert 0, 36
  bb2:
    mstore 128, v1
    returndata 128, 32
}

// CHECK-LABEL: {{^[ +].*}}fn @third{{[( ]}}
// CHECK: {{^[ +].*}}mstore 4, 18
// CHECK: {{^[ +].*}}revert 0, 36
fn @third(arg0: u256) {
  bb0:
    v1 = sub arg0, 1
    v2 = gt v1, arg0
    br v2, bb1, bb2
  bb1:
    mstore 0, 0x4e487b7100000000000000000000000000000000000000000000000000000000
    mstore 4, 18
    revert 0, 36
  bb2:
    mstore 128, v1
    returndata 128, 32
}

// CHECK-LABEL: + fn @__revert_stub{{[0-9]+}}
// CHECK: + mstore 4, 17
// CHECK: + revert 0, 36
