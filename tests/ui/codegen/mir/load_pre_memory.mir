//@compile-flags: --pass load-pre
// Memory shapes are analyzed but never rewritten: the backend lowers phis
// through memory spill slots (a store per predecessor plus a load at the
// use), which costs more than the 3-gas MLOAD a rewrite would save. These
// functions lock in the cost-model gate; keccak and storage reads keep
// their rewrites (see the other load_pre tests).
; module @LoadPreMemory
fn @mload_full_diamond(arg0: bool) -> u256 {
  bb0 (entry):
    br arg0, bb1, bb2
  bb1:
    v1 = mload 128
    jump bb3
  bb2:
    v2 = mload 128
    jump bb3
  bb3:
    v3 = mload 128
    ret v3
}

fn @mstore_forwarding(arg0: bool, arg1: u256) -> u256 {
  bb0 (entry):
    br arg0, bb1, bb2
  bb1:
    mstore 128, arg1
    jump bb3
  bb2:
    v2 = mload 128
    jump bb3
  bb3:
    v3 = mload 128
    ret v3
}

fn @mstore8_overlap_kills(arg0: bool) -> u256 {
  bb0 (entry):
    v1 = mload 128
    br arg0, bb1, bb2
  bb1:
    mstore8 159, 7
    br arg0, bb3, bb4
  bb2:
    jump bb3
  bb3:
    v2 = mload 128
    ret v2
  bb4:
    ret v1
}

fn @mload_partial_rejected(arg0: bool) -> u256 {
  bb0 (entry):
    br arg0, bb1, bb2
  bb1:
    v1 = mload 128
    jump bb3
  bb2:
    jump bb3
  bb3:
    v2 = mload 128
    ret v2
}

fn @mload_partial_two_available(arg0: u256) -> u256 {
  bb0 (entry):
    switch arg0, default bb3, [1 => bb1, 2 => bb2]
  bb1:
    v1 = mload 128
    jump bb4
  bb2:
    v2 = mload 128
    jump bb4
  bb3:
    jump bb4
  bb4:
    v3 = mload 128
    ret v3
}

fn @staticcall_kills_memory(arg0: bool, arg1: address) -> u256 {
  bb0 (entry):
    v1 = mload 128
    br arg0, bb1, bb2
  bb1:
    v2 = staticcall 100000, arg1, 0, 0, 0, 0
    br arg0, bb3, bb4
  bb2:
    jump bb3
  bb3:
    v3 = mload 128
    ret v3
  bb4:
    ret v1
}

fn @msize_blocks_memory(arg0: bool) -> u256 {
  bb0 (entry):
    br arg0, bb1, bb2
  bb1:
    v1 = mload 128
    jump bb3
  bb2:
    v2 = mload 128
    jump bb3
  bb3:
    v3 = msize
    v4 = mload 128
    v5 = add v3, v4
    ret v5
}
