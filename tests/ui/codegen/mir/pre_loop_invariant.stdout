// === ROOT/tests/ui/codegen/mir/pre_loop_invariant.mir (after pre) ===
; module @LoopInvariant
fn @hoist_header_expr(arg0: u256, arg1: u256) -> u256 {
  bb0 (entry):
    v10 = add arg0, 7
    jump bb1
  bb1:
    v3 = phi [bb0: arg0], [bb2: v2]
    v11 = phi [bb0: v10], [bb2: v9]
    v6 = lt v11, arg1
    br v6, bb2, bb3
  bb2:
    v2 = add v3, 1
    v9 = add v2, 7
    jump bb1
  bb3:
    ret v11
}

fn @hoist_header_expr_two_latches(arg0: u256, arg1: u256) -> u256 {
  bb0 (entry):
    v15 = add arg0, 7
    jump bb1
  bb1:
    v4 = phi [bb0: arg0], [bb3: v2], [bb4: v3]
    v16 = phi [bb0: v15], [bb3: v11], [bb4: v14]
    v7 = lt v16, arg1
    br v7, bb2, bb5
  bb2:
    switch arg1, default bb3, [1 => bb4]
  bb3:
    v2 = add v4, 1
    v11 = add v2, 7
    jump bb1
  bb4:
    v3 = add v4, 2
    v14 = add v3, 7
    jump bb1
  bb5:
    ret v16
}
