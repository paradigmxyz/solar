// === ROOT/tests/ui/codegen/mir/cfg_simplify_phi_forwarders.mir (after cfg-simplify) ===
@module CfgSimplifyPhiForwarders
fn @keep_conflicting_diamond(arg0: bool) -> u256 {
  bb0 (entry):
    br arg0, bb3, bb2
  bb1:
    invalid
  bb2:
    jump bb3
  bb3:
    v0 = phi [bb0: 1], [bb2: 2]
    ret v0
}

fn @fold_equal_value_diamond(arg0: bool) -> u256 {
  bb0 (entry):
    br arg0, bb3, bb2
  bb1:
    invalid
  bb2:
    jump bb3
  bb3:
    v0 = phi [bb0: 7], [bb2: 7]
    ret v0
}
