- // === ROOT/tests/ui/codegen/mir/evm-inst-schedule/operand_order.mir (before evm-inst-schedule) ===
+ // === ROOT/tests/ui/codegen/mir/evm-inst-schedule/operand_order.mir (after evm-inst-schedule) ===
  @module EvmInstSchedule
  fn @binary_push_order(arg0: u256, arg1: u256, arg2: u256, arg3: u256) -> u256 {
    bb0:
-     v0 = add arg0, arg1
      v1 = mul arg2, arg3
+     v0 = add arg0, arg1
      v2 = sub v0, v1
      ret v2
  }
  
  fn @read_order(arg0: u256, arg1: u256) -> u256 {
    bb0:
-     v0 = calldataload arg0
      v1 = sload arg1
+     v0 = calldataload arg0
      v2 = sub v0, v1
      ret v2
  }
  
  fn @commutative_tree_order(arg0: u256, arg1: u256) {
    bb0:
      v0 = add arg0, 31
      v1 = and v0, 0xffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffe0
      v2 = add arg1, 64
      v3 = sub v1, 32
      v4 = add v2, v3
      mstore v4, 0
      stop
  }
  
  fn @shared_value_order(arg0: u256, arg1: u256) -> u256 {
    bb0:
      v0 = add arg0, 31
      v1 = and v0, 0xffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffe0
      v2 = add arg1, 64
      v3 = sub v1, 32
      v4 = add v2, v3
      mstore v4, 0
      v5 = add v1, 64
      ret v5
  }
  
  fn @effect_barriers(arg0: u256, arg1: u256) -> u256 {
    bb0:
      v0 = add arg0, 1
      mstore 0, v0
      v1 = mul arg1, 2
      v2 = gas
      v3 = sub v1, v2
      ret v3
  }
  
