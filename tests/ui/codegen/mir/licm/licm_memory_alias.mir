//@compile-flags: --pass licm
@module LicmMemoryAlias
immutables:
  value: u256

fn @hoist_non_aliasing_mload() -> u256 {
  bb0 (entry):
    jump bb1
  bb1:
    br true, bb2, bb3
  bb2:
    v0 = mload 0
    mstore 64, 1
    jump bb1
  bb3:
    ret v0
}

fn @keep_aliasing_mload() -> u256 {
  bb0 (entry):
    jump bb1
  bb1:
    br true, bb2, bb3
  bb2:
    v0 = mload 0
    mstore 16, 1
    jump bb1
  bb3:
    ret v0
}

fn @hoist_non_aliasing_keccak() -> bytes32 {
  bb0 (entry):
    jump bb1
  bb1:
    br true, bb2, bb3
  bb2:
    v0 = keccak256 0, 32
    mstore 64, 1
    jump bb1
  bb3:
    ret v0
}

fn @keep_aliasing_keccak() -> bytes32 {
  bb0 (entry):
    jump bb1
  bb1:
    br true, bb2, bb3
  bb2:
    v0 = keccak256 0, 32
    mstore 16, 1
    jump bb1
  bb3:
    ret v0
}

fn @hoist_unassigned_immutable() -> u256 {
  bb0 (entry):
    jump bb1
  bb1:
    br true, bb2, bb3
  bb2:
    v0 = loadimmutable value
    v1 = mul v0, 2
    jump bb1
  bb3:
    ret v1
}

fn @keep_assigned_immutable() -> u256 {
  bb0 (entry):
    jump bb1
  bb1:
    br true, bb2, bb3
  bb2:
    v0 = loadimmutable value
    v1 = mul v0, 2
    storeimmutable value, 1
    jump bb1
  bb3:
    ret v1
}
