//@compile-flags: --pass licm
//@filecheck:
@module LicmMemoryAlias
// CHECK-LABEL: {{^[ +].*}}fn @hoist_non_aliasing_mload{{[( ]}}
// CHECK: + [[LOAD:v[0-9]+]] = mload 0
// CHECK: - [[LOAD]] = mload 0
fn @hoist_non_aliasing_mload() -> u256 {
  bb0:
    jump bb1
  bb1:
    br true, bb2, bb3
  bb2:
    v0 = mload 0
    mstore 64, 1
    jump bb1
  bb3:
    ret v0
}

// CHECK-LABEL: {{^[ +].*}}fn @keep_aliasing_mload{{[( ]}}
// CHECK: {{^[ +].*}}mload 0
// CHECK: {{^[ +].*}}mstore 16
fn @keep_aliasing_mload() -> u256 {
  bb0:
    jump bb1
  bb1:
    br true, bb2, bb3
  bb2:
    v0 = mload 0
    mstore 16, 1
    jump bb1
  bb3:
    ret v0
}

// CHECK-LABEL: {{^[ +].*}}fn @hoist_non_aliasing_keccak{{[( ]}}
// CHECK: + [[HASH:v[0-9]+]] = keccak256 0, 32
// CHECK: - [[HASH]] = keccak256 0, 32
fn @hoist_non_aliasing_keccak() -> bytes32 {
  bb0:
    jump bb1
  bb1:
    br true, bb2, bb3
  bb2:
    v0 = keccak256 0, 32
    mstore 64, 1
    jump bb1
  bb3:
    ret v0
}

// CHECK-LABEL: {{^[ +].*}}fn @keep_aliasing_keccak{{[( ]}}
// CHECK: {{^[ +].*}}keccak256 0, 32
// CHECK: {{^[ +].*}}mstore 16
fn @keep_aliasing_keccak() -> bytes32 {
  bb0:
    jump bb1
  bb1:
    br true, bb2, bb3
  bb2:
    v0 = keccak256 0, 32
    mstore 16, 1
    jump bb1
  bb3:
    ret v0
}
