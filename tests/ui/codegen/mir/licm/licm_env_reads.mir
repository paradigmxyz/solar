//@compile-flags: --pass licm
//@filecheck:
@module LicmEnvReads

// The value-transferring call can change the queried balance between iterations,
// so neither the balance nor the mul depending on it may be hoisted.
// CHECK-LABEL: fn @keep_balance_with_call
// CHECK: [[BALANCE:v[0-9]+]] = balance 0xbeef
// CHECK: call
fn @keep_balance_with_call() -> u256 {
  bb0:
    jump bb1
  bb1:
    br true, bb2, bb3
  bb2:
    v0 = balance 0xbeef
    v1 = mul v0, 3
    v2 = call 1000, 0xbeef, 1, 0, 0, 0, 0
    jump bb1
  bb3:
    ret v1
}

// Without any call or create in the loop the balance is loop-invariant for real.
// CHECK-LABEL: fn @hoist_balance_without_calls
// CHECK: + [[BALANCE:v[0-9]+]] = balance 0xbeef
// CHECK: + [[SCALED:v[0-9]+]] = mul [[BALANCE]], 3
// CHECK: - [[BALANCE]] = balance 0xbeef
fn @hoist_balance_without_calls() -> u256 {
  bb0:
    jump bb1
  bb1:
    br true, bb2, bb3
  bb2:
    v0 = balance 0xbeef
    v1 = mul v0, 3
    jump bb1
  bb3:
    ret v1
}

// The created contract's constructor can run arbitrary code.
// CHECK-LABEL: fn @keep_extcodesize_with_create
// CHECK: extcodesize
// CHECK: create
fn @keep_extcodesize_with_create() -> u256 {
  bb0:
    jump bb1
  bb1:
    br true, bb2, bb3
  bb2:
    v0 = extcodesize 0xbeef
    v1 = mul v0, 3
    v2 = create 0, 0, 32
    jump bb1
  bb3:
    ret v1
}

// Every external call, including staticcall, rewrites the return-data buffer.
// CHECK-LABEL: fn @keep_returndatasize_with_staticcall
// CHECK: returndatasize
// CHECK: staticcall
fn @keep_returndatasize_with_staticcall() -> u256 {
  bb0:
    jump bb1
  bb1:
    br true, bb2, bb3
  bb2:
    v0 = returndatasize
    v1 = mul v0, 3
    v2 = staticcall 1000, 0xbeef, 0, 0, 0, 0
    jump bb1
  bb3:
    ret v1
}

// msize observes memory expansion and must never move.
// CHECK-LABEL: fn @keep_msize
// CHECK: msize
fn @keep_msize() -> u256 {
  bb0:
    jump bb1
  bb1:
    br true, bb2, bb3
  bb2:
    v0 = msize
    v1 = mul v0, 3
    jump bb1
  bb3:
    ret v1
}
