//@compile-flags: --pass licm
@module LicmV2
fn @hoist_symbolic_offset_sload(arg0: u256) -> u256 {
  bb0:
    jump bb1
  bb1:
    v1 = phi [bb0: 0], [bb2: v7]
    v2 = lt v1, 4
    br v2, bb2, bb3
  bb2:
    v3 = add arg0, 1
    v4 = sload v3
    v5 = add arg0, 2
    sstore v5, 9
    v7 = add v1, 1
    jump bb1
  bb3:
    ret v4
}

fn @keep_aliasing_symbolic_offset_sload(arg0: u256) -> u256 {
  bb0:
    jump bb1
  bb1:
    v1 = phi [bb0: 0], [bb2: v7]
    v2 = lt v1, 4
    br v2, bb2, bb3
  bb2:
    v3 = add arg0, 1
    v4 = sload v3
    v5 = add arg0, 1
    sstore v5, 9
    v7 = add v1, 1
    jump bb1
  bb3:
    ret v4
}

fn @do_not_speculate_symbolic_offset_sload(arg0: u256, arg1: bool) -> u256 {
  bb0:
    jump bb1
  bb1:
    br arg1, bb2, bb3
  bb2:
    v1 = add arg0, 1
    v2 = sload v1
    v3 = add arg0, 2
    sstore v3, 9
    jump bb1
  bb3:
    ret v2
}

fn @hoist_affine_memory_base(arg0: u256) -> u256 {
  bb0:
    jump bb1
  bb1:
    v1 = phi [bb0: 0], [bb2: v7]
    v2 = lt v1, 4
    br v2, bb2, bb3
  bb2:
    v3 = add arg0, 32
    v4 = mul v1, 32
    v5 = add v3, v4
    mstore v5, v1
    v7 = add v1, 1
    jump bb1
  bb3:
    ret 0
}

fn @hoist_unknown_trip_affine_memory_base(arg0: u256, arg1: u256) -> u256 {
  bb0:
    jump bb1
  bb1:
    v1 = phi [bb0: 0], [bb2: v7]
    v2 = lt v1, arg1
    br v2, bb2, bb3
  bb2:
    v3 = add arg0, 32
    v4 = mul v1, 32
    v5 = add v3, v4
    mstore v5, v1
    v7 = add v1, 1
    jump bb1
  bb3:
    ret 0
}
