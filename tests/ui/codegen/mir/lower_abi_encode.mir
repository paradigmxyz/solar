//@compile-flags: --passes lower-abi-encode
; module @LowerAbiEncode

fn @static(arg0: u256) -> memoryslice {
  bb0 (entry):
    v0 = abi_encode [word], selector 0x1234567800000000000000000000000000000000000000000000000000000000, args arg0
    ret v0
}

fn @dynamic(arg0: calldataslice) -> memoryslice {
  bb0 (entry):
    v0 = abi_encode [calldata_bytes], args arg0
    ret v0
}
