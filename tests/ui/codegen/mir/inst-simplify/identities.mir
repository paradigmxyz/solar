//@compile-flags: --pass inst-simplify
//@filecheck: --enable-var-scope
@module InstSimplifyIdentities

// CHECK-LABEL: @add_zero
// CHECK: +     ret arg0
fn @add_zero(arg0: u256) -> u256 {
  bb0:
    v1 = add arg0, 0
    ret v1
}

// CHECK-LABEL: @mul_one
// CHECK: +     ret arg0
fn @mul_one(arg0: u256) -> u256 {
  bb0:
    v1 = mul 1, arg0
    ret v1
}

// CHECK-LABEL: @self_sub
// CHECK: +     ret 0
fn @self_sub(arg0: u256) -> u256 {
  bb0:
    v1 = sub arg0, arg0
    ret v1
}

// CHECK-LABEL: @idempotent_logic
// CHECK: +     ret arg0, arg0, 0
fn @idempotent_logic(arg0: u256) -> (u256, u256, u256) {
  bb0:
    v1 = and arg0, arg0
    v2 = or arg0, arg0
    v3 = xor arg0, arg0
    ret v1, v2, v3
}

// CHECK-LABEL: @not_not
// CHECK: +     ret arg0
fn @not_not(arg0: u256) -> u256 {
  bb0:
    v1 = not arg0
    v2 = not v1
    ret v2
}

// CHECK-LABEL: @iszero_immediate
// CHECK: +     ret 1
fn @iszero_immediate() -> bool {
  bb0:
    v0 = iszero 0
    ret v0
}

// CHECK-LABEL: @eq_zero
// CHECK: +     [[ZERO:v[0-9]+]] = iszero arg0
// CHECK:       ret [[ZERO]]
fn @eq_zero(arg0: u256) -> bool {
  bb0:
    v1 = eq arg0, 0
    ret v1
}

// CHECK-LABEL: @and_all_ones
// CHECK: +     ret arg0
fn @and_all_ones(arg0: u256) -> u256 {
  bb0:
    v1 = and 0xffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffff, arg0
    ret v1
}

// CHECK-LABEL: @address_mask
// CHECK:       [[ADDRESS:v[0-9]+]] = address
// CHECK: +     ret [[ADDRESS]]
fn @address_mask() -> address {
  bb0:
    v0 = address
    v1 = and v0, 0xffffffffffffffffffffffffffffffffffffffff
    ret v1
}

// CHECK-LABEL: @own_balance
// CHECK: +     [[BALANCE:v[0-9]+]] = selfbalance
// CHECK:       ret [[BALANCE]]
fn @own_balance() -> u256 {
  bb0:
    v0 = address
    v1 = balance v0
    ret v1
}

// CHECK-LABEL: @invert_iszero_branch
// CHECK: +     br arg0, bb2, bb1
fn @invert_iszero_branch(arg0: u256) {
  bb0:
    v1 = lt 0, arg0
    v2 = iszero v1
    br v2, bb1, bb2
  bb1:
    stop
  bb2:
    stop
}

// CHECK-LABEL: @masked_own_balance
// CHECK: +     [[BALANCE:v[0-9]+]] = selfbalance
// CHECK:       ret [[BALANCE]]
fn @masked_own_balance() -> u256 {
  bb0:
    v0 = address
    v1 = and v0, 0xffffffffffffffffffffffffffffffffffffffff
    v2 = balance v1
    ret v2
}
