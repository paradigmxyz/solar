// === ROOT/tests/ui/codegen/mir/cse_environment.mir (after cse) ===
; module @CseEnvironment
fn @keep_cheap_nullary_environment_reads(arg0: u256) -> u256 {
  bb0 (entry):
    v1 = caller
    v2 = caller
    v3 = callvalue
    v4 = callvalue
    v5 = calldatasize
    v6 = calldatasize
    v7 = chainid
    v8 = chainid
    v9 = add v1, v2
    v10 = add v3, v4
    v11 = add v5, v6
    v12 = add v7, v8
    v13 = add v9, v10
    v14 = add v11, v12
    v15 = add v13, v14
    v16 = add v15, arg0
    ret v16
}

fn @reuse_expensive_environment_reads(arg0: address, arg1: u256) -> u256 {
  bb0 (entry):
    v2 = balance arg0
    v4 = extcodesize arg0
    v6 = extcodehash arg0
    v8 = blockhash arg1
    v10 = blobhash arg1
    v12 = add v2, v2
    v13 = add v4, v4
    v14 = add v6, v6
    v15 = add v8, v8
    v16 = add v10, v10
    v17 = add v12, v13
    v18 = add v14, v15
    v19 = add v17, v18
    v20 = add v19, v16
    ret v20
}

fn @invalidate_account_reads_after_call(arg0: address) -> u256 {
  bb0 (entry):
    v1 = balance arg0
    v2 = extcodehash arg0
    v9 = call 0x186a0, arg0, 0, 0, 0, 0, 0
    v10 = balance arg0
    v11 = extcodehash arg0
    v12 = add v1, v10
    v13 = add v2, v11
    v14 = add v12, v13
    v15 = add v14, v9
    ret v15
}

fn @keep_gas_uncached() -> u256 {
  bb0 (entry):
    v0 = gas
    v1 = gas
    v2 = add v0, v1
    ret v2
}
