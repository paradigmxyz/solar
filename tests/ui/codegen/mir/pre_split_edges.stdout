// === ROOT/tests/ui/codegen/mir/pre_split_edges.mir (after pre) ===
; module @SplitEdges
fn @switch_pred_two_cases(arg0: u256, arg1: u256) -> u256 {
  bb0 (entry):
    switch arg1, default bb1, [1 => bb2]
  bb1:
    v4 = add arg0, 7
    jump bb3
  bb2:
    switch arg1, default bb4, [2 => bb5, 3 => bb5]
  bb3:
    v10 = phi [bb1: v4], [bb5: v9]
    ret v10
  bb4:
    ret arg0
  bb5:
    v9 = add arg0, 7
    jump bb3
}

fn @branch_both_arms_to_join(arg0: u256, arg1: bool) -> u256 {
  bb0 (entry):
    br arg1, bb1, bb2
  bb1:
    v3 = add arg0, 7
    jump bb3
  bb2:
    br arg1, bb4, bb4
  bb3:
    v7 = phi [bb1: v3], [bb4: v6]
    ret v7
  bb4:
    v6 = add arg0, 7
    jump bb3
}

fn @self_loop_backedge_insertion(arg0: u256, arg1: u256) -> u256 {
  bb0 (entry):
    jump bb1
  bb1:
    v3 = add arg0, 7
    jump bb2
  bb2:
    v5 = phi [bb1: arg0], [bb4: v4]
    v11 = phi [bb1: v3], [bb4: v10]
    v4 = add v5, 1
    v9 = lt v4, arg1
    br v9, bb4, bb3
  bb3:
    ret v11
  bb4:
    v10 = add v4, 7
    jump bb2
}

fn @hoist_through_branch_preheader(arg0: u256, arg1: u256) -> u256 {
  bb0 (entry):
    v2 = lt arg0, arg1
    br v2, bb5, bb4
  bb1:
    v4 = phi [bb5: arg0], [bb2: v3]
    v12 = phi [bb2: v10], [bb5: v11]
    v7 = lt v12, arg1
    br v7, bb2, bb3
  bb2:
    v3 = add v4, 1
    v10 = add v3, 7
    jump bb1
  bb3:
    ret v12
  bb4:
    ret arg0
  bb5:
    v11 = add arg0, 7
    jump bb1
}
