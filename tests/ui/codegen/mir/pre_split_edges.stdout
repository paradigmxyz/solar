// === ROOT/tests/ui/codegen/mir/pre_split_edges.mir (after pre) ===
@module SplitEdges
fn @switch_pred_two_cases(arg0: u256, arg1: u256) -> u256 {
  bb0 (entry):
    switch arg1, default bb1, [1 => bb2]
  bb1:
    v0 = add arg0, 7
    jump bb3
  bb2:
    switch arg1, default bb4, [2 => bb5, 3 => bb5]
  bb3:
    v3 = phi [bb1: v0], [bb5: v2]
    ret v3
  bb4:
    ret arg0
  bb5:
    v2 = add arg0, 7
    jump bb3
}

fn @branch_both_arms_to_join(arg0: u256, arg1: bool) -> u256 {
  bb0 (entry):
    br arg1, bb1, bb2
  bb1:
    v0 = add arg0, 7
    jump bb3
  bb2:
    br arg1, bb4, bb4
  bb3:
    v3 = phi [bb1: v0], [bb4: v2]
    ret v3
  bb4:
    v2 = add arg0, 7
    jump bb3
}

fn @self_loop_backedge_insertion(arg0: u256, arg1: u256) -> u256 {
  bb0 (entry):
    jump bb1
  bb1:
    v0 = add arg0, 7
    jump bb2
  bb2:
    v1 = phi [bb1: arg0], [bb4: v2]
    v6 = phi [bb1: v0], [bb4: v5]
    v2 = add v1, 1
    v4 = lt v2, arg1
    br v4, bb4, bb3
  bb3:
    ret v6
  bb4:
    v5 = add v2, 7
    jump bb2
}

fn @hoist_through_branch_preheader(arg0: u256, arg1: u256) -> u256 {
  bb0 (entry):
    v0 = lt arg0, arg1
    br v0, bb5, bb4
  bb1:
    v1 = phi [bb5: arg0], [bb2: v4]
    v7 = phi [bb2: v5], [bb5: v6]
    v3 = lt v7, arg1
    br v3, bb2, bb3
  bb2:
    v4 = add v1, 1
    v5 = add v4, 7
    jump bb1
  bb3:
    ret v7
  bb4:
    ret arg0
  bb5:
    v6 = add arg0, 7
    jump bb1
}
