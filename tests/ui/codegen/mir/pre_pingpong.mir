//@compile-flags: --passes pre
// Two join blocks that are mutual predecessors: eliminating the expression
// from one join inserts it into the other, which used to ping-pong forever.
// The pass must terminate after the single profitable rewrite in bb5.
; module @PingPong
fn @pingpong(arg0: u256, arg1: u256) {
  bb0 (entry):
    switch arg1, default bb1, [1 => bb2, 2 => bb3, 3 => bb4]
  bb1:
    v2 = add arg0, 7
    jump bb5
  bb2:
    v3 = add arg0, 7
    jump bb5
  bb3:
    v4 = add arg0, 7
    jump bb6
  bb4:
    v5 = add arg0, 7
    jump bb6
  bb5:
    v6 = add arg0, 7
    jump bb6
  bb6:
    jump bb5
}
