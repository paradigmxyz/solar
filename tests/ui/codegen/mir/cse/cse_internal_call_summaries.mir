//@compile-flags: --pass cse
//@filecheck:
@module CseInternalCallSummaries
// CHECK-LABEL: {{^[ +].*}}fn @keep_load_across_reader{{[( ]}}
// CHECK: - {{v[0-9]+}} = mload arg0
// CHECK: + {{v[0-9]+}} = add [[LOAD:v[0-9]+]], [[LOAD]]
fn @keep_load_across_reader(arg0: memptr) -> u256 {
  bb0:
    v1 = mload arg0
    v2 = internal_call fn3, 1, arg0
    v3 = mload arg0
    v4 = add v1, v3
    v5 = add v4, v2
    ret v5
}

// CHECK-LABEL: {{^[ +].*}}fn @invalidate_load_across_writer{{[( ]}}
// CHECK: {{^[ +].*}}{{v[0-9]+}} = mload arg0
// CHECK: {{^[ +].*}}{{v[0-9]+}} = mload arg0
fn @invalidate_load_across_writer(arg0: memptr) -> u256 {
  bb0:
    v1 = mload arg0
    internal_call fn4, 0, arg0
    v2 = mload arg0
    v3 = add v1, v2
    ret v3
}

// CHECK-LABEL: {{^[ +].*}}fn @preserve_freshness_across_call{{[( ]}}
// CHECK: - {{v[0-9]+}} = mload {{v[0-9]+}}
// CHECK: + {{v[0-9]+}} = add [[FRESH:v[0-9]+]], [[FRESH]]
fn @preserve_freshness_across_call() -> u256 {
  bb0:
    v0 = alloc raw, exact, uninitialized, infallible, 32
    v1 = mload v0
    internal_call fn5, 0
    v2 = alloc raw, exact, uninitialized, infallible, 32
    mstore v2, 7
    v3 = mload v0
    v4 = add v1, v3
    ret v4
}

fn @reader(arg0: memptr) -> u256 {
  bb0:
    v1 = mload arg0
    ret v1
}

fn @writer(arg0: memptr) {
  bb0:
    mstore arg0, 9
    ret
}

fn @noop() {
  bb0:
    ret
}
