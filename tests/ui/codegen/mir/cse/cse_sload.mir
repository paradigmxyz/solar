//@compile-flags: --pass cse
//@filecheck:
// Two SLOADs from the same slot within a block (no intervening SSTORE)
// should be CSE'd. But after an SSTORE, the cache is invalidated.
@module CseSload
// CHECK-LABEL: fn @sload_cse
// CHECK: - {{v[0-9]+}} = sload arg0
// CHECK: + {{v[0-9]+}} = add [[LOAD:v[0-9]+]], [[LOAD]]
fn @sload_cse(arg0: u256) -> u256 {
  bb0:
    v1 = sload arg0
    v2 = sload arg0
    v3 = add v1, v2
    ret v3
}

// CHECK-LABEL: fn @sload_after_sstore
// CHECK: [[BEFORE:v[0-9]+]] = sload arg0
// CHECK: [[AFTER:v[0-9]+]] = sload arg0
fn @sload_after_sstore(arg0: u256, arg1: u256) -> u256 {
  bb0:
    v2 = sload arg0
    sstore arg0, arg1
    v4 = sload arg0
    v5 = add v2, v4
    ret v5
}
