//@compile-flags: --pass cse
//@filecheck:
@module CseEnvironment
// CHECK-LABEL: {{^[ +].*}}fn @keep_cheap_nullary_environment_reads{{[( ]}}
// CHECK: {{^[ +].*}}{{v[0-9]+}} = caller
// CHECK: {{^[ +].*}}{{v[0-9]+}} = caller
// CHECK: {{^[ +].*}}{{v[0-9]+}} = callvalue
// CHECK: {{^[ +].*}}{{v[0-9]+}} = callvalue
fn @keep_cheap_nullary_environment_reads(arg0: u256) -> u256 {
  bb0:
    v1 = caller
    v2 = caller
    v3 = callvalue
    v4 = callvalue
    v5 = calldatasize
    v6 = calldatasize
    v7 = chainid
    v8 = chainid
    v9 = add v1, v2
    v10 = add v3, v4
    v11 = add v5, v6
    v12 = add v7, v8
    v13 = add v9, v10
    v14 = add v11, v12
    v15 = add v13, v14
    v16 = add v15, arg0
    ret v16
}

// CHECK-LABEL: {{^[ +].*}}fn @reuse_expensive_environment_reads{{[( ]}}
// CHECK: - {{v[0-9]+}} = balance arg0
// CHECK: - {{v[0-9]+}} = extcodesize arg0
// CHECK: - {{v[0-9]+}} = extcodehash arg0
// CHECK: - {{v[0-9]+}} = blockhash arg1
// CHECK: - {{v[0-9]+}} = blobhash arg1
fn @reuse_expensive_environment_reads(arg0: address, arg1: u256) -> u256 {
  bb0:
    v1 = balance arg0
    v2 = balance arg0
    v3 = extcodesize arg0
    v4 = extcodesize arg0
    v5 = extcodehash arg0
    v6 = extcodehash arg0
    v7 = blockhash arg1
    v8 = blockhash arg1
    v9 = blobhash arg1
    v10 = blobhash arg1
    v11 = add v1, v2
    v12 = add v3, v4
    v13 = add v5, v6
    v14 = add v7, v8
    v15 = add v9, v10
    v16 = add v11, v12
    v17 = add v13, v14
    v18 = add v16, v17
    v19 = add v18, v15
    ret v19
}

// CHECK-LABEL: {{^[ +].*}}fn @invalidate_account_reads_after_call{{[( ]}}
// CHECK: {{^[ +].*}}{{v[0-9]+}} = balance arg0
// CHECK: {{^[ +].*}}{{v[0-9]+}} = balance arg0
fn @invalidate_account_reads_after_call(arg0: address) -> u256 {
  bb0:
    v1 = balance arg0
    v2 = extcodehash arg0
    v3 = call 100000, arg0, 0, 0, 0, 0, 0
    v4 = balance arg0
    v5 = extcodehash arg0
    v6 = add v1, v4
    v7 = add v2, v5
    v8 = add v6, v7
    v9 = add v8, v3
    ret v9
}

// CHECK-LABEL: {{^[ +].*}}fn @keep_gas_uncached{{[( ]}}
// CHECK: {{^[ +].*}}{{v[0-9]+}} = gas
// CHECK: {{^[ +].*}}{{v[0-9]+}} = gas
fn @keep_gas_uncached() -> u256 {
  bb0:
    v1 = gas
    v2 = gas
    v3 = add v1, v2
    ret v3
}
