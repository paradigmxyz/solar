//@compile-flags: --pass cse
//@filecheck:
@module CseAllocationProvenance

// The reload of a fresh (unreused) allocation is CSE'd away in `@fresh`; the
// diff shows the second `mload` removed and the sum folded to one load.
// CHECK-LABEL: {{^[ +].*}}fn @fresh{{[( ]}}
// CHECK: {{^[ +].*}}[[LOAD:v[0-9]+]] = mload {{v[0-9]+}}
// CHECK: - {{v[0-9]+}} = mload {{v[0-9]+}}
// CHECK: + [[SUM:v[0-9]+]] = add [[LOAD]], [[LOAD]]
// CHECK: {{^[ +].*}}ret [[SUM]]
fn @fresh(arg0: u256, arg1: u256) -> u256 {
  bb0:
    v2 = alloc raw, exact, uninitialized, infallible, 32
    v3 = alloc raw, exact, uninitialized, infallible, 32
    mstore v2, arg0
    v5 = mload v2
    mstore v3, arg1
    v7 = mload v2
    v8 = add v5, v7
    ret v8
}

// A reset free-memory pointer reuses the address, so `@reset` keeps both
// loads: its lines stay unchanged context in the diff.
// CHECK-LABEL: {{^[ +].*}}fn @reset{{[( ]}}
// CHECK: {{^[ +].*}}[[FIRST:v[0-9]+]] = mload {{v[0-9]+}}
// CHECK: {{^[ +].*}}[[SECOND:v[0-9]+]] = mload {{v[0-9]+}}
// CHECK: {{^[ +].*}}[[SUM:v[0-9]+]] = add [[FIRST]], [[SECOND]]
// CHECK: {{^[ +].*}}ret [[SUM]]
fn @reset(arg0: u256, arg1: u256) -> u256 {
  bb0:
    v2 = alloc raw, exact, uninitialized, infallible, 32
    mstore v2, arg0
    v4 = mload v2
    set_fmp v2
    v6 = alloc raw, exact, uninitialized, infallible, 32
    mstore v6, arg1
    v8 = mload v2
    v9 = add v4, v8
    ret v9
}
