//@compile-flags: --pass cse
//@filecheck:
@module CseMemoryAlias
// CHECK-LABEL: fn @reuse_same_memory_load
// CHECK: - {{v[0-9]+}} = mload arg0
// CHECK: + {{v[0-9]+}} = add [[SAME:v[0-9]+]], [[SAME]]
fn @reuse_same_memory_load(arg0: u256) -> u256 {
  bb0:
    v1 = mload arg0
    v2 = mload arg0
    v3 = add v1, v2
    ret v3
}

// CHECK-LABEL: fn @reuse_after_disjoint_memory_store
// CHECK: - {{v[0-9]+}} = mload 64
// CHECK: + {{v[0-9]+}} = add [[DISJOINT:v[0-9]+]], [[DISJOINT]]
fn @reuse_after_disjoint_memory_store(arg0: u256) -> u256 {
  bb0:
    v1 = mload 64
    v2 = mload 64
    mstore 96, arg0
    v4 = mload 64
    v5 = add v1, v2
    v6 = add v5, v4
    ret v6
}

// CHECK-LABEL: fn @keep_after_overlapping_memory_store
// CHECK: {{v[0-9]+}} = mload 64
// CHECK: {{v[0-9]+}} = mload 64
fn @keep_after_overlapping_memory_store(arg0: u256) -> u256 {
  bb0:
    v1 = mload 64
    mstore 80, arg0
    v3 = mload 64
    v4 = add v1, v3
    ret v4
}

// CHECK-LABEL: fn @reuse_keccak_after_disjoint_memory_store
// CHECK: - {{v[0-9]+}} = keccak256 128, 64
// CHECK: + {{v[0-9]+}} = add [[HASH:v[0-9]+]], [[HASH]]
fn @reuse_keccak_after_disjoint_memory_store(arg0: u256) -> u256 {
  bb0:
    v1 = keccak256 128, 64
    mstore 64, arg0
    v3 = keccak256 128, 64
    v4 = add v1, v3
    ret v4
}

// CHECK-LABEL: fn @reuse_mload_after_disjoint_call_return
// CHECK: - {{v[0-9]+}} = mload 64
// CHECK: + {{v[0-9]+}} = add [[CALL_LOAD:v[0-9]+]], [[CALL_LOAD]]
fn @reuse_mload_after_disjoint_call_return(arg0: u256) -> u256 {
  bb0:
    v1 = mload 64
    v2 = call 100000, arg0, 0, 0, 0, 96, 32
    v3 = mload 64
    v4 = add v1, v3
    v5 = add v4, v2
    ret v5
}

// CHECK-LABEL: fn @keep_mload_after_overlapping_call_return
// CHECK: {{v[0-9]+}} = mload 96
// CHECK: {{v[0-9]+}} = mload 96
fn @keep_mload_after_overlapping_call_return(arg0: u256) -> u256 {
  bb0:
    v1 = mload 96
    v2 = call 100000, arg0, 0, 0, 0, 96, 32
    v3 = mload 96
    v4 = add v1, v3
    v5 = add v4, v2
    ret v5
}
