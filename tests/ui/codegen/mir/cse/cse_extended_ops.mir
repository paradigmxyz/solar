//@compile-flags: --pass cse
//@filecheck:
@module CseExtendedOps
// CHECK-LABEL: fn @extended_pure_ops
// CHECK: - {{v[0-9]+}} = sdiv arg0, arg1
// CHECK: - {{v[0-9]+}} = smod arg0, arg1
// CHECK: - {{v[0-9]+}} = sar arg1, arg0
// CHECK: - {{v[0-9]+}} = signextend arg1, arg0
// CHECK: - {{v[0-9]+}} = addmod arg1, arg0, 97
// CHECK: - {{v[0-9]+}} = select arg2, arg0, arg1
fn @extended_pure_ops(arg0: u256, arg1: u256, arg2: bool) -> (u256, u256, u256, u256, u256, bool) {
  bb0:
    v3 = sdiv arg0, arg1
    v4 = sdiv arg0, arg1
    v5 = smod arg0, arg1
    v6 = smod arg0, arg1
    v7 = sar arg1, arg0
    v8 = sar arg1, arg0
    v9 = signextend arg1, arg0
    v10 = signextend arg1, arg0
    v11 = addmod arg0, arg1, 97
    v12 = addmod arg1, arg0, 97
    v13 = select arg2, arg0, arg1
    v14 = select arg2, arg0, arg1
    ret v4, v6, v8, v10, v12, v14
}

// CHECK-LABEL: fn @calldata_reads
// CHECK: - {{v[0-9]+}} = calldataload arg0
fn @calldata_reads(arg0: u256) -> u256 {
  bb0:
    v1 = calldataload arg0
    v2 = calldataload arg0
    ret v2
}
