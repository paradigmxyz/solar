//@compile-flags: --pass cse
@module CseGlobalLoads
fn @dominating_mload(arg0: bool) -> u256 {
  bb0:
    mstore 0, 11
    v1 = mload 0
    br arg0, bb1, bb2
  bb1:
    v2 = mload 0
    ret v2
  bb2:
    mstore 0, 22
    v3 = mload 0
    ret v3
}

fn @dominating_sload(arg0: bool) -> u256 {
  bb0:
    v1 = sload 0
    br arg0, bb1, bb2
  bb1:
    v2 = sload 0
    ret v2
  bb2:
    sstore 0, 7
    v3 = sload 0
    ret v3
}
