//@compile-flags: --pass cse
@module CseGlobalLoads
immutables:
  value: u256

fn @dominating_mload(arg0: bool) -> u256 {
  bb0:
    mstore 0, 11
    v1 = mload 0
    br arg0, bb1, bb2
  bb1:
    v2 = mload 0
    ret v2
  bb2:
    mstore 0, 22
    v3 = mload 0
    ret v3
}

fn @dominating_sload(arg0: bool) -> u256 {
  bb0:
    v1 = sload 0
    br arg0, bb1, bb2
  bb1:
    v2 = sload 0
    ret v2
  bb2:
    sstore 0, 7
    v3 = sload 0
    ret v3
}

fn @dominating_loadimmutable(arg0: bool) -> u256 {
  bb0:
    v1 = loadimmutable value
    br arg0, bb1, bb2
  bb1:
    v2 = loadimmutable value
    ret v2
  bb2:
    storeimmutable value, 7
    v3 = loadimmutable value
    ret v3
}

fn @keep_phi_immutable_loads_before_branch_stores(arg0: bool) -> u256 {
  bb0:
    br arg0, bb1, bb2
  bb1:
    v1 = loadimmutable value
    storeimmutable value, 1
    jump bb3
  bb2:
    v2 = loadimmutable value
    storeimmutable value, 2
    jump bb3
  bb3:
    v3 = phi [bb1: v1], [bb2: v2]
    ret v3
}
