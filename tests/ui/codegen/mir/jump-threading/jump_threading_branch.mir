//@compile-flags: --pass jump-threading
//@filecheck:
// A conditional branch whose two targets are empty forwarder blocks.
// Jump threading should rewrite the branch to point past the forwarders.
@module ThreadingBranch
// CHECK-LABEL: {{^[ +].*}}fn @branch_forwarders{{[( ]}}
// CHECK: - jumpi arg0, bb1, bb2
// CHECK: + jumpi arg0, bb3, bb4
fn @branch_forwarders(arg0: u256) -> u256 {
  bb0:
    jumpi arg0, bb1, bb2
  bb1:
    jump bb3
  bb2:
    jump bb4
  bb3:
    ret arg0
  bb4:
    ret arg0
}
