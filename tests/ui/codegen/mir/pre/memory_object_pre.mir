//@compile-flags: --pass pre
//@filecheck:
@module MemoryObjectPre

// CHECK-LABEL: fn @hoist_projection
// CHECK: + [[INSERTED:v[0-9]+]] = memory_object_field_addr
// CHECK: + [[MERGE:v[0-9]+]] = phi [bb1: [[AVAILABLE:v[0-9]+]]], [bb2: [[INSERTED]]]
// CHECK: + ret [[MERGE]]
fn @hoist_projection(arg0: memorystruct, arg1: bool) -> memptr {
  bb0:
    br arg1, bb1, bb2
  bb1:
    v2 = memory_object_field_addr memorystruct<3>, arg0, 2
    jump bb3
  bb2:
    jump bb3
  bb3:
    v3 = memory_object_field_addr memorystruct<3>, arg0, 2
    ret v3
}
