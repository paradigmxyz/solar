//@compile-flags: --pass pre
//@filecheck:
@module Pre
// CHECK-LABEL: fn @insert_missing_predecessor
// CHECK: + [[INSERTED:v[0-9]+]] = add arg0, 7
// CHECK: + [[MERGE:v[0-9]+]] = phi [bb1: [[LEFT:v[0-9]+]]], [bb2: [[RIGHT:v[0-9]+]]], [bb3: [[INSERTED]]]
fn @insert_missing_predecessor(arg0: u256, arg1: u256) -> u256 {
  bb0:
    switch arg1, default bb3, [1 => bb1, 2 => bb2]
  bb1:
    v2 = add arg0, 7
    jump bb4
  bb2:
    v3 = add 7, arg0
    jump bb4
  bb3:
    jump bb4
  bb4:
    v4 = add arg0, 7
    ret v4
}

// CHECK-LABEL: fn @translate_join_phi
// CHECK: + [[INSERTED:v[0-9]+]] = add arg2, 1
// CHECK: + [[MERGE:v[0-9]+]] = phi [bb1: [[LEFT:v[0-9]+]]], [bb2: [[RIGHT:v[0-9]+]]], [bb3: [[INSERTED]]]
fn @translate_join_phi(arg0: u256, arg1: u256, arg2: u256, arg3: u256) -> u256 {
  bb0:
    switch arg3, default bb3, [1 => bb1, 2 => bb2]
  bb1:
    v4 = add arg0, 1
    jump bb4
  bb2:
    v5 = add arg1, 1
    jump bb4
  bb3:
    jump bb4
  bb4:
    v6 = phi [bb1: arg0], [bb2: arg1], [bb3: arg2]
    v7 = add v6, 1
    ret v7
}

// CHECK-LABEL: fn @two_way_join
// CHECK: + [[INSERTED:v[0-9]+]] = add arg0, 1
// CHECK: + [[MERGE:v[0-9]+]] = phi [bb1: [[AVAILABLE:v[0-9]+]]], [bb2: [[INSERTED]]]
fn @two_way_join(arg0: u256, arg1: bool) -> u256 {
  bb0:
    br arg1, bb1, bb2
  bb1:
    v2 = add arg0, 1
    jump bb3
  bb2:
    jump bb3
  bb3:
    v3 = add arg0, 1
    ret v3
}

// CHECK-LABEL: fn @split_branch_terminated_pred
// CHECK: + br arg1, bb5, bb4
// CHECK: + [[MERGE:v[0-9]+]] = phi [bb1: [[AVAILABLE:v[0-9]+]]], [bb5: [[INSERTED:v[0-9]+]]]
// CHECK: + [[INSERTED]] = add arg0, 1
fn @split_branch_terminated_pred(arg0: u256, arg1: bool) -> u256 {
  bb0:
    br arg1, bb1, bb2
  bb1:
    v2 = add arg0, 1
    jump bb3
  bb2:
    br arg1, bb3, bb4
  bb3:
    v3 = add arg0, 1
    ret v3
  bb4:
    ret arg0
}
