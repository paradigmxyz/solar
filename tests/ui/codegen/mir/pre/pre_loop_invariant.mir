//@compile-flags: --passes pre
//@filecheck:
// Loop-invariant PRE: the header expression's translated form is available at
// the latch end and insertable in the jump-terminated preheader, so it is
// hoisted out of the loop and the header gets a phi.
@module LoopInvariant
// CHECK-LABEL: fn @hoist_header_expr
// CHECK: + [[HOISTED:v[0-9]+]] = add arg0, 7
// CHECK: + [[VALUE:v[0-9]+]] = phi [bb0: [[HOISTED]]], [bb2: {{v[0-9]+}}]
// CHECK: + ret [[VALUE]]
fn @hoist_header_expr(arg0: u256, arg1: u256) -> u256 {
  bb0:
    jump bb1
  bb1:
    v2 = phi [bb0: arg0], [bb2: v5]
    v3 = add v2, 7
    v4 = lt v3, arg1
    br v4, bb2, bb3
  bb2:
    v5 = add v2, 1
    v6 = add v5, 7
    jump bb1
  bb3:
    ret v3
}

// CHECK-LABEL: fn @hoist_header_expr_two_latches
// CHECK: + [[HOISTED:v[0-9]+]] = add arg0, 7
// CHECK: + [[VALUE:v[0-9]+]] = phi [bb0: [[HOISTED]]], [bb3: {{v[0-9]+}}], [bb4: {{v[0-9]+}}]
// CHECK: + ret [[VALUE]]
fn @hoist_header_expr_two_latches(arg0: u256, arg1: u256) -> u256 {
  bb0:
    jump bb1
  bb1:
    v2 = phi [bb0: arg0], [bb3: v5], [bb4: v8]
    v3 = add v2, 7
    v4 = lt v3, arg1
    br v4, bb2, bb5
  bb2:
    switch arg1, default bb3, [1 => bb4]
  bb3:
    v5 = add v2, 1
    v6 = add v5, 7
    jump bb1
  bb4:
    v8 = add v2, 2
    v9 = add v8, 7
    jump bb1
  bb5:
    ret v3
}
