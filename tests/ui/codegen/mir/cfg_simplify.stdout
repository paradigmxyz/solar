// === ROOT/tests/ui/codegen/mir/cfg_simplify.mir (after cfg-simplify) ===
; module @CfgSimplify
fn @sequential(arg0: u256) -> u256 {
  bb0 (entry):
    v2 = add arg0, 1
    v4 = add v2, 1
    v6 = add v4, 1
    ret v6
  bb1:
    invalid
  bb2:
    invalid
}

fn @branch_forwarder_preserves_successor_order(arg0: bool) -> u256 {
  bb0 (entry):
    br arg0, bb1, bb2
  bb1:
    ret 1
  bb2:
    ret 2
  bb3:
    invalid
}

fn @degenerate_branch_refreshes_successors(arg0: bool) -> u256 {
  bb0 (entry):
    ret 1
  bb1:
    invalid
}
