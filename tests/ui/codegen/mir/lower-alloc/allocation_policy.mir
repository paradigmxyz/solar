//@compile-flags: --passes lower-alloc
//@filecheck:
@module AllocationPolicy

// CHECK-LABEL: fn @checked
// CHECK: + [[PTR:v[0-9]+]] = mload 64
// CHECK: + br [[OVERFLOW:v[0-9]+]], bb2, bb1
// CHECK: + calldatacopy [[PTR]], {{v[0-9]+}}, {{v[0-9]+}}
// CHECK: + revert 0, 36
fn @checked(arg0: u256) -> memorybytes {
  bb0:
    v1 = alloc memorybytes, word, zeroed, panic, arg0
    ret v1
}

// CHECK-LABEL: fn @internal
// CHECK: + [[PTR:v[0-9]+]] = mload 64
// CHECK: + mstore 64, {{v[0-9]+}}
fn @internal() -> memptr {
  bb0:
    v0 = alloc raw, exact, uninitialized, infallible, 32
    ret v0
}
