//@compile-flags: --passes lower-alloc
//@filecheck:
@module LowerAlloc

// CHECK-LABEL: fn @operations
// CHECK: + {{v[0-9]+}} = mload 64
// CHECK: + [[NEXT:v[0-9]+]] = add {{v[0-9]+}}, 64
// CHECK: + mstore 64, [[NEXT]]
fn @operations(arg0: u256) -> memptr {
  bb0:
    v1 = fmp
    set_fmp v1
    v2 = alloc raw, word, uninitialized, infallible, 64
    mstore v2, arg0
    ret v2
}

// CHECK-LABEL: fn @deferred
// CHECK: alloc raw{{.*}}!metadata(deferred_alloc)
fn @deferred() {
  bb0:
    v0 = alloc raw, exact, uninitialized, infallible, 32 !metadata(deferred_alloc)
    mstore v0, 1
    stop
}
