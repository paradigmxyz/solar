//@ check-pass
//@compile-flags: --passes sroa,dce
@module Sroa

fn @local_struct(arg0: u256, arg1: u256) -> u256 {
  bb0:
    v0 = alloc memorystruct<2>, exact, uninitialized, infallible, 64
    v1 = memory_object_field_addr memorystruct<2>, v0, 0
    mstore v1, arg0
    v2 = memory_object_field_addr memorystruct<2>, v0, 1
    mstore v2, arg1
    v3 = memory_object_field_addr memorystruct<2>, v0, 0
    v4 = mload v3
    v5 = memory_object_field_addr memorystruct<2>, v0, 1
    v6 = mload v5
    v7 = add v4, v6
    ret v7
}
