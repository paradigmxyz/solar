// === ROOT/tests/ui/codegen/mir/licm_v2.mir (after licm) ===
; module @LicmV2
fn @hoist_symbolic_offset_sload(arg0: u256) -> u256 {
  bb0 (entry):
    v7 = add arg0, 1
    v8 = sload v7 !metadata(storage=offset(arg0, 1))
    v10 = add arg0, 2
    jump bb1
  bb1:
    v3 = phi [bb0: 0], [bb2: v2]
    v5 = lt v3, 4
    br v5, bb2, bb3
  bb2:
    sstore v10, 9 !metadata(storage=offset(arg0, 2))
    v2 = add v3, 1
    jump bb1
  bb3:
    ret v8
}

fn @keep_aliasing_symbolic_offset_sload(arg0: u256) -> u256 {
  bb0 (entry):
    v7 = add arg0, 1
    v10 = add arg0, 1
    jump bb1
  bb1:
    v3 = phi [bb0: 0], [bb2: v2]
    v5 = lt v3, 4
    br v5, bb2, bb3
  bb2:
    v8 = sload v7 !metadata(storage=offset(arg0, 1))
    sstore v10, 9 !metadata(storage=offset(arg0, 1))
    v2 = add v3, 1
    jump bb1
  bb3:
    ret v8
}

fn @do_not_speculate_symbolic_offset_sload(arg0: u256, arg1: bool) -> u256 {
  bb0 (entry):
    jump bb1
  bb1:
    br arg1, bb2, bb3
  bb2:
    v3 = add arg0, 1
    v4 = sload v3 !metadata(storage=offset(arg0, 1))
    v6 = add arg0, 2
    sstore v6, 9 !metadata(storage=offset(arg0, 2))
    jump bb1
  bb3:
    ret v4
}

fn @hoist_affine_memory_base(arg0: u256) -> u256 {
  bb0 (entry):
    v7 = add arg0, 32
    jump bb1
  bb1:
    v3 = phi [bb0: 0], [bb2: v2]
    v5 = lt v3, 4
    br v5, bb2, bb3
  bb2:
    v9 = mul v3, 32
    v10 = add v7, v9
    mstore v10, v3
    v2 = add v3, 1
    jump bb1
  bb3:
    ret 0
}
