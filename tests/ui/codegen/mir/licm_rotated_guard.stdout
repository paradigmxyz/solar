// === ROOT/tests/ui/codegen/mir/licm_rotated_guard.mir (after licm) ===
; module @LicmRotatedGuard
fn @rotated_guard_overlap() -> u256 {
  bb0 (entry):
    jump bb1
  bb1:
    v2 = phi [bb0: 0], [bb2: v1]
    v4 = mul v2, 32
    mstore v4, 1
    v7 = mload 320
    v9 = lt v2, 10
    br v9, bb2, bb3
  bb2:
    v1 = add v2, 1
    jump bb1
  bb3:
    ret v7
}

