// === ROOT/tests/ui/codegen/mir/licm_rotated_guard.mir (after licm) ===
; module @LicmRotatedGuard
fn @rotated_guard_overlap() -> u256 {
  bb0 (entry):
    jump bb1
  bb1:
    v0 = phi [bb0: 0], [bb2: v4]
    v1 = mul v0, 32
    mstore v1, 1
    v2 = mload 320
    v3 = lt v0, 10
    br v3, bb2, bb3
  bb2:
    v4 = add v0, 1
    jump bb1
  bb3:
    ret v2
}

