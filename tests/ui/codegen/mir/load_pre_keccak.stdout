// === ROOT/tests/ui/codegen/mir/load_pre_keccak.mir (after load-pre) ===
; module @LoadPreKeccak
fn @keccak_same_dynamic_size(arg0: bool, arg1: u256) -> u256 {
  bb0 (entry):
    br arg0, bb1, bb2
  bb1:
    v3 = keccak256 0, arg1
    jump bb3
  bb2:
    v5 = keccak256 0, arg1
    jump bb3
  bb3:
    v8 = phi [bb1: v3], [bb2: v5]
    ret v8
}

fn @keccak_different_dynamic_size(arg0: bool, arg1: u256, arg2: u256) -> u256 {
  bb0 (entry):
    br arg0, bb1, bb2
  bb1:
    v4 = keccak256 0, arg1
    jump bb3
  bb2:
    v6 = keccak256 0, arg1
    jump bb3
  bb3:
    v8 = keccak256 0, arg2
    ret v8
}
