// === ROOT/tests/ui/codegen/mir/pre_pingpong.mir (after pre) ===
; module @PingPong
fn @pingpong(arg0: u256, arg1: u256) {
  bb0 (entry):
    switch arg1, default bb1, [1 => bb2, 2 => bb3, 3 => bb4]
  bb1:
    v6 = add arg0, 7
    jump bb5
  bb2:
    v8 = add arg0, 7
    jump bb5
  bb3:
    v10 = add arg0, 7
    jump bb6
  bb4:
    v12 = add arg0, 7
    jump bb6
  bb5:
    v16 = phi [bb1: v6], [bb2: v8], [bb6: v15]
    jump bb6
  bb6:
    v15 = add arg0, 7
    jump bb5
}
