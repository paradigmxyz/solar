//@compile-flags: --pass storage-dse
//@filecheck:
@module StorageDse
// CHECK-LABEL: fn @remove_overwritten_store
// CHECK: - sstore 0, arg0
// CHECK: + sstore 0, 7
fn @remove_overwritten_store(arg0: u256) {
  bb0:
    sstore 0, arg0
    sstore 0, 7
    stop
}

// CHECK-LABEL: fn @keep_store_observed_by_load
// CHECK: + sstore 0, arg0
// CHECK: + [[LOAD:v[0-9]+]] = sload 0
// CHECK: + sstore 0, 7
fn @keep_store_observed_by_load(arg0: u256) -> u256 {
  bb0:
    sstore 0, arg0
    v1 = sload 0
    sstore 0, 7
    ret v1
}

// CHECK-LABEL: fn @remove_equal_store_after_load
// CHECK: - sstore 0, arg0
// CHECK: - {{.*}}sload 0
// CHECK: - sstore 0, arg0
// CHECK: + sstore 0, arg0
// CHECK: + [[LOAD:v[0-9]+]] = sload 0
fn @remove_equal_store_after_load(arg0: u256) -> u256 {
  bb0:
    sstore 0, arg0
    v1 = sload 0
    sstore 0, arg0
    ret v1
}

// CHECK-LABEL: fn @keep_may_alias_symbolic_store
// CHECK: + sstore arg0, 1
// CHECK: + sstore arg1, 2
fn @keep_may_alias_symbolic_store(arg0: u256, arg1: u256) {
  bb0:
    sstore arg0, 1
    sstore arg1, 2
    stop
}

// CHECK-LABEL: fn @remove_disjoint_offset_overwrite
// CHECK: - sstore {{v[0-9]+}}, 1
// CHECK: + sstore {{v[0-9]+}}, 3
fn @remove_disjoint_offset_overwrite(arg0: u256) {
  bb0:
    v1 = add arg0, 1
    sstore v1, 1
    v2 = add arg0, 2
    sstore v2, 2
    v3 = add arg0, 1
    sstore v3, 3
    stop
}

// CHECK-LABEL: fn @keep_across_call
// CHECK: + sstore 0, arg0
// CHECK: call
// CHECK: + sstore 0, 7
fn @keep_across_call(arg0: u256, arg1: address) {
  bb0:
    sstore 0, arg0
    v1 = call 100000, arg1, 0, 0, 0, 0, 0
    sstore 0, 7
    stop
}
