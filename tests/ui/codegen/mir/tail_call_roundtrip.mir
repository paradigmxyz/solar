//@compile-flags: --pass dce
// `tail_call` round-trips through the text format: control transfers to the
// callee and does not return, so the case block needs no trailing terminator.
// The arity is validated against the callee (one u256 argument here).
; module @TailCallRoundtrip [phase = dispatch]
fn @wrapper(arg0: u256) {
  bb0 (entry):
    mstore 128, arg0
    returndata 128, 32
}
fn @entry() {
  bb0 (entry):
    v1 = calldataload 0
    v3 = shr 224, v1
    v4 = eq v3, 0x9507d39a
    br v4, bb1, bb2
  bb1:
    v6 = calldataload 4
    tail_call fn0, v6
  bb2:
    revert 0, 0
}
