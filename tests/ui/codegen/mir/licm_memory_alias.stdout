fn @hoist_non_aliasing_mload() -> u256 {
  bb0 (entry):
    v2 = mload 0
    jump bb1
  bb1:
    br 1, bb2, bb3
  bb2:
    mstore 64, 1
    jump bb1
  bb3:
    ret v2
}

fn @keep_aliasing_mload() -> u256 {
  bb0 (entry):
    jump bb1
  bb1:
    br 1, bb2, bb3
