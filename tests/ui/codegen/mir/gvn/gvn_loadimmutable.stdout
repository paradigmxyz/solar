- // === ROOT/tests/ui/codegen/mir/gvn/gvn_loadimmutable.mir (before gvn) ===
+ // === ROOT/tests/ui/codegen/mir/gvn/gvn_loadimmutable.mir (after gvn) ===
  @module GvnLoadImmutable
  immutables:
    first: u256
    second: u256
  
  fn @same_immutable_stays() -> u256 {
    bb0 (entry):
      v0 = loadimmutable first
      v1 = loadimmutable first
      v2 = add v0, v1
      ret v2
  }
  
  fn @different_immutables_stay(arg0: u256) -> u256 {
    bb0 (entry):
      v0 = loadimmutable first
      v1 = loadimmutable second
      v2 = add v0, v1
      ret v2
  }
  
  fn @store_prevents_merge(arg0: u256) -> u256 {
    bb0 (entry):
      v0 = loadimmutable first
      storeimmutable first, arg0
      v1 = loadimmutable first
      v2 = add v0, v1
      ret v2
  }
  
