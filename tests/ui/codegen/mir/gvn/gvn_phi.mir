//@compile-flags: --pass gvn
//@filecheck:
@module GvnPhi

// Two phis in one block with pairwise-congruent incoming collapse to one.
// CHECK-LABEL: {{^[ +].*}}fn @congruent_phis_collapse{{[( ]}}
// CHECK: - {{v[0-9]+}} = phi [bb1: arg0], [bb2: arg1]
// CHECK: + {{v[0-9]+}} = add [[PHI:v[0-9]+]], [[PHI]]
fn @congruent_phis_collapse(arg0: u256, arg1: u256, arg2: bool) -> u256 {
  bb0:
    jumpi arg2, bb1, bb2
  bb1:
    jump bb3
  bb2:
    jump bb3
  bb3:
    v3 = phi [bb1: arg0], [bb2: arg1]
    v4 = phi [bb1: arg0], [bb2: arg1]
    v5 = add v3, v4
    ret v5
}

// Phi-of-same folds onto the operand because its def dominates the join.
// CHECK-LABEL: {{^[ +].*}}fn @phi_of_same_folds_to_dominating_operand{{[( ]}}
// CHECK: - {{v[0-9]+}} = phi [bb1: {{v[0-9]+}}], [bb2: {{v[0-9]+}}]
// CHECK: + {{v[0-9]+}} = mul {{v[0-9]+}}, 2
fn @phi_of_same_folds_to_dominating_operand(arg0: u256, arg1: bool) -> u256 {
  bb0:
    v2 = add arg0, 1
    jumpi arg1, bb1, bb2
  bb1:
    jump bb3
  bb2:
    jump bb3
  bb3:
    v3 = phi [bb1: v2], [bb2: v2]
    v4 = mul v3, 2
    ret v4
}

// The incoming values are distinct defs in one class: v3 folds onto v2, and
// the phi-of-same then folds onto the class leader v2 as well.
// CHECK-LABEL: {{^[ +].*}}fn @phi_of_congruent_incoming{{[( ]}}
// CHECK: - {{v[0-9]+}} = phi [bb1: {{v[0-9]+}}], [bb2: {{v[0-9]+}}]
// CHECK: + ret {{v[0-9]+}}
fn @phi_of_congruent_incoming(arg0: u256, arg1: bool) -> u256 {
  bb0:
    v2 = add arg0, 1
    jumpi arg1, bb1, bb2
  bb1:
    v3 = add arg0, 1
    jump bb3
  bb2:
    jump bb3
  bb3:
    v4 = phi [bb1: v3], [bb2: v2]
    ret v4
}

// Phi-of-same over equal immediates folds onto the constant.
// CHECK-LABEL: {{^[ +].*}}fn @phi_of_equal_immediates{{[( ]}}
// CHECK: + ret 7
fn @phi_of_equal_immediates(arg0: bool) -> u256 {
  bb0:
    jumpi arg0, bb1, bb2
  bb1:
    jump bb3
  bb2:
    jump bb3
  bb3:
    v1 = phi [bb1: 7], [bb2: 7]
    ret v1
}

// Documents current behavior: the two phis evolve in lockstep, but pessimistic
// iteration starts them in distinct classes and nothing ever merges them -
// unifying lockstep loop phis needs optimistic NewGVN-style assumptions.
// CHECK-LABEL: {{^[ +].*}}fn @lockstep_loop_phis_stay{{[( ]}}
// CHECK: {{^[ +].*}}[[A:v[0-9]+]] = phi [bb0: 0], [bb2: [[NEXT_A:v[0-9]+]]]
// CHECK: {{^[ +].*}}[[B:v[0-9]+]] = phi [bb0: 0], [bb2: [[NEXT_B:v[0-9]+]]]
// CHECK: {{^[ +].*}}[[NEXT_A]] = add [[A]], 1
// CHECK: {{^[ +].*}}[[NEXT_B]] = add [[B]], 1
fn @lockstep_loop_phis_stay(arg0: u256) -> u256 {
  bb0:
    jump bb1
  bb1:
    v1 = phi [bb0: 0], [bb2: v4]
    v2 = phi [bb0: 0], [bb2: v5]
    v3 = lt v1, arg0
    jumpi v3, bb2, bb3
  bb2:
    v4 = add v1, 1
    v5 = add v2, 1
    jump bb1
  bb3:
    v6 = add v1, v2
    ret v6
}
