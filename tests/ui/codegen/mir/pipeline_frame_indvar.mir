//@compile-flags: --pipeline-default
; module @PipelineFrameIndVar
fn @frame_counter_feeds_affine_address(arg0: u256, arg1: u256) -> u256 {
  bb0 (entry):
    v1 = internal_frame_addr 128
    mstore v1, 0
    jump bb1
  bb1:
    v2 = internal_frame_addr 128
    v3 = mload v2
    v4 = lt v3, arg0
    br v4, bb2, bb3
  bb2:
    v5 = mul v3, 32
    v6 = add arg1, v5
    mstore v6, v3
    v7 = add v3, 1
    v8 = internal_frame_addr 128
    mstore v8, v7
    jump bb1
  bb3:
    ret 0
}
