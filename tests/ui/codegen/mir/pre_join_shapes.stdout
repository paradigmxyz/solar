; module @JoinShapes
fn @duplicate_pred_edges(arg0: u256, arg1: u256, arg2: u256) -> u256 {
  bb0 (entry):
    switch arg1, default bb1, [1 => bb2, 2 => bb3]
  bb1:
    v6 = add arg0, 7
    jump bb4
  bb2:
    v8 = add arg0, 7
    switch arg2, default bb4, [1 => bb4]
  bb3:
    v12 = add arg0, 7
    jump bb4
  bb4:
    v13 = phi [bb1: v6], [bb2: v8], [bb3: v12]
    ret v13
}

fn @self_loop_join(arg0: u256, arg1: u256) -> u256 {
  bb0 (entry):
    switch arg1, default bb3, [1 => bb1, 2 => bb2]
  bb1:
    v5 = add arg0, 7
    jump bb4
  bb2:
    v7 = add arg0, 7
    jump bb4
  bb3:
    v11 = add arg0, 7
    jump bb4
  bb4:
    v12 = phi [bb1: v5], [bb2: v7], [bb3: v11], [bb4: v12]
    v10 = eq arg1, v12
    br v10, bb4, bb5
  bb5:
    ret v12
}

fn @outer_phi_operand(arg0: u256, arg1: u256) -> u256 {
  bb0 (entry):
    jump bb1
  bb1:
    v3 = phi [bb0: arg0], [bb6: v2]
    switch arg1, default bb2, [1 => bb3, 2 => bb4]
  bb2:
    v7 = add v3, 7
    jump bb5
  bb3:
    v9 = add 7, v3
    jump bb5
  bb4:
    v14 = add v3, 7
    jump bb5
  bb5:
    v15 = phi [bb2: v7], [bb3: v9], [bb4: v14]
    v12 = lt v15, arg1
    br v12, bb6, bb7
  bb6:
    v2 = add v3, 1
    jump bb1
  bb7:
    ret v15
}
