// === ROOT/tests/ui/codegen/mir/cfg_simplify_trivial_phi.mir (after cfg-simplify,dce) ===
; module @CfgSimplifyTrivialPhi
fn @fold_same_value_phi(arg0: u256, arg1: bool) -> u256 {
  bb0 (entry):
    br arg1, bb1, bb2
  bb1:
    log0 0, 0
    jump bb3
  bb2:
    log0 0, 0
    jump bb3
  bb3:
    ret arg0
}

fn @fold_self_incoming_phi(arg0: u256, arg1: bool) -> u256 {
  bb0 (entry):
    jump bb1
  bb1:
    br arg1, bb2, bb3
  bb2:
    log0 0, 0
    jump bb1
  bb3:
    ret arg0
}
