@module AddmodMulmod
fn @am(arg0: u256, arg1: u256, arg2: u256) {
  bb0 (entry):
    v0 = calldatasize
    v1 = sub v0, 4
    v2 = slt v1, 96
    br v2, bb1, bb2
  bb1:
    revert 0, 0
  bb2:
    mstore 128, 0
    v3 = addmod arg0, arg1, arg2
    mstore 128, v3
    returndata 128, 32
}

