//@ compile-flags: -Zcodegen
//@ filecheck:
// CHECK: "errors": [
// CHECK: "severity": "error"
// CHECK: "message": "EVM codegen requires MIR in the `evm-shaped` phase, stopped at `abi`"
// CHECK-NOT: "contracts"
{
  "language": "Solidity",
  "sources": {
    "Fallback.sol": {
      "content": "contract C { fallback(bytes calldata input) external returns (bytes memory) { return input; } }"
    }
  },
  "settings": {
    "outputSelection": {
      "*": {
        "*": [
          "evm.bytecode.object",
          "evm.deployedBytecode.object"
        ]
      }
    }
  }
}
