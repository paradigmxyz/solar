// CHECK: expected `uint256`, found `bool`
// CHECK-NOT: "contracts"
{
  "language": "Solidity",
  "sources": {
    "A.sol": {
      "content": "contract A { function f() public pure { uint x = true; } }"
    }
  },
  "settings": {
    "outputSelection": {
      "*": {
        "*": [
          "abi"
        ]
      }
    }
  }
}
