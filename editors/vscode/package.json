{
  "name": "solar-lsp",
  "displayName": "Solar LSP",
  "description": "Solidity language support with LSP and formatting",
  "version": "0.1.0",
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/paradigmxyz/solar.git",
    "directory": "editors/vscode"
  },
  "bugs": {
    "url": "https://github.com/paradigmxyz/solar/issues"
  },
  "homepage": "https://github.com/paradigmxyz/solar/tree/main/editors/vscode",
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Formatters",
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:solidity"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "solidity",
        "aliases": [
          "Solidity",
          "solidity"
        ],
        "extensions": [
          ".sol"
        ],
        "configuration": "language-configuration.json"
      },
      {
        "id": "solidity-markdown-injection"
      }
    ],
    "grammars": [
      {
        "language": "solidity",
        "scopeName": "source.solidity",
        "path": "./syntaxes/solidity.json"
      },
      {
        "language": "solidity-markdown-injection",
        "scopeName": "markdown.solidity.codeblock",
        "path": "./syntaxes/solidity-markdown-injection.json",
        "injectTo": [
          "text.html.markdown"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.solidity": "solidity"
        }
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Solar LSP Configuration",
      "properties": {
        "solarLsp.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable Solar LSP"
        },
        "solarLsp.serverPath": {
          "type": "string",
          "default": "solar",
          "description": "Path to solar executable"
        },
        "solarLsp.forgePath": {
          "type": "string",
          "default": "forge",
          "description": "Path to forge executable"
        },
        "solarLsp.formatOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Format files on save using Solar LSP"
        },
        "solarLsp.flychecks": {
          "type": [
            "array",
            "null"
          ],
          "default": null,
          "description": "Flycheck commands to run on save. Leave unset to auto-detect forge lint when available.",
          "items": {
            "type": "object",
            "required": [
              "id",
              "command"
            ],
            "properties": {
              "id": {
                "type": "string",
                "description": "Stable diagnostic owner id for this flycheck"
              },
              "command": {
                "type": "string",
                "description": "Command to execute"
              },
              "args": {
                "type": "array",
                "default": [],
                "items": {
                  "type": "string"
                },
                "description": "Command arguments"
              },
              "cwd": {
                "type": "string",
                "description": "Working directory relative to the workspace root, or an absolute path"
              },
              "output": {
                "type": "string",
                "default": "solc-json",
                "enum": [
                  "solc-json",
                  "forge-lint-json"
                ],
                "description": "JSON diagnostic output format"
              }
            }
          }
        }
      }
    },
    "commands": [
      {
        "command": "solarLsp.formatDocument",
        "title": "Format Document",
        "category": "Solar"
      },
      {
        "command": "solar.clearCache",
        "title": "Clear Analysis Cache",
        "category": "Solar"
      },
      {
        "command": "solar.reindex",
        "title": "Reindex Workspace",
        "category": "Solar"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.125.0",
    "@types/node": "26.x",
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "vscode-languageclient": "^10.1.0"
  }
}
